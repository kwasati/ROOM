---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
}

const { title, description = 'เรียนเทรดฟรี จากประสบการณ์จริง — IntensiveTrader Room', ogImage, ogImageWidth = 1280, ogImageHeight = 720 } = Astro.props;
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content={String(ogImageWidth)} />}
    {ogImage && <meta property="og:image:height" content={String(ogImageHeight)} />}
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+Thai:wght@400;500;600;700&family=Press+Start+2P&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-dark text-gray-light">
    <Navbar />
    <main>
      <slot />
    </main>
    <footer class="border-t border-dark-border mt-16 py-8 px-4 text-center">
      <p class="text-sm text-gray mb-1.5">โบรกที่ผมเทรดเอง: <a href="https://affs.click/jih0m" target="_blank" rel="noopener noreferrer sponsored" class="text-secondary font-semibold hover:underline">XM — เปิดบัญชี (รหัสผู้แนะนำ KWASATI) →</a></p>
      <p class="text-xs text-gray-dark">ลิงก์แนะนำ (affiliate) · ไม่ใช่คำแนะนำการลงทุน · การเทรดมีความเสี่ยง</p>
    </footer>
  </body>
</html>
