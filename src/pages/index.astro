---
import Layout from '../layouts/Layout.astro';
import BrokerCTA from '../components/BrokerCTA.astro';
import { getCollection, render } from 'astro:content';
import { eaItems } from '../data/ea';

const courses = (await getCollection('courses')).sort((a, b) => a.data.order - b.data.order);
const allLessons = (await getCollection('lessons')).sort((a, b) => a.data.order - b.data.order);

const lessonCounts = new Map<string, number>();
for (const lesson of allLessons) {
  lessonCounts.set(lesson.data.course, (lessonCounts.get(lesson.data.course) || 0) + 1);
}
const totalLessons = allLessons.length;

// Pre-render lesson content (inline toggle for courses)
const renderedLessons = new Map<string, { id: string; title: string; duration?: string; order: number; course: string; Content: any }[]>();
for (const lesson of allLessons) {
  const { Content } = await render(lesson);
  const courseId = lesson.data.course;
  if (!renderedLessons.has(courseId)) renderedLessons.set(courseId, []);
  renderedLessons.get(courseId)!.push({
    id: lesson.id.split('/').pop()!,
    title: lesson.data.title,
    duration: lesson.data.duration,
    order: lesson.data.order,
    course: courseId,
    Content,
  });
}

// Normalize courses -> unified card shape
const courseItems = courses.map(c => ({
  kind: 'course' as const,
  id: c.id,
  title: c.data.title,
  description: c.data.description,
  count: lessonCounts.get(c.id) || 0,
  isLearn: c.data.courseType === 'learn',
  cardType: c.data.courseType, // 'learn' | 'learn-tool'
  pinned: c.data.pinned ?? false,
  pinOrder: c.data.pinOrder,
}));

type Item = (typeof eaItems)[number] | (typeof courseItems)[number];
const allItems: Item[] = [...eaItems, ...courseItems];

const pinnedItems = allItems
  .filter(i => i.pinned)
  .sort((a, b) => (a.pinOrder ?? 999) - (b.pinOrder ?? 999));
const restItems = allItems.filter(i => !i.pinned);

const learnCount = allItems.filter(i => i.cardType === 'learn' || i.cardType === 'learn-tool').length;
const eaCount = allItems.filter(i => i.cardType === 'ea').length;
---

<Layout title="Room — เรียน+เทรดฟรี | IntensiveTrader">
  <div id="main-content" class="room-index">

    <!-- INTRO -->
    <section class="room-intro">
      <div class="max-w-[1100px] mx-auto px-5 room-intro-grid">
        <div>
          <h1 class="text-[30px] max-md:text-[24px] font-bold text-gray-light leading-tight mb-2">
            เรียน<span class="text-primary">+</span>เทรด<br><span class="text-secondary">ฟรีทั้งหมด</span>
          </h1>
          <p class="text-[15px] text-gray max-w-[520px] leading-relaxed">
            คอร์สมือใหม่ + เครื่องมือเทรด (EA) สำหรับ MT5 — โหลดใช้ได้เลย ไม่มีค่าใช้จ่าย ไม่มีเงื่อนไข
          </p>
        </div>
        <div class="room-intro-rail">
          <div class="room-index-signature pixel" aria-hidden="true"><span>ROOM</span><small>OPEN CLASSROOM</small></div>
          <dl class="room-stats" aria-label="จำนวนเนื้อหา">
            <div><dt>คอร์ส</dt><dd>{courses.length}</dd></div>
            <div><dt>EA</dt><dd>{eaItems.length}</dd></div>
            <div><dt>บทเรียน</dt><dd>{totalLessons}</dd></div>
          </dl>
        </div>
      </div>
    </section>

    <!-- CATALOG -->
    <section class="room-catalog max-w-[1100px] mx-auto px-5" aria-label="รายการเนื้อหาใน Room">
      <div class="catalog-toolbar">
        <div class="filter-pills" id="course-filter" role="group" aria-label="กรองรายการ">
          <button data-filter="all" class="filter-btn active" aria-pressed="true">ทั้งหมด<span>{allItems.length}</span></button>
          <button data-filter="learn" class="filter-btn" aria-pressed="false">คอร์สเรียน<span>{learnCount}</span></button>
          <button data-filter="ea" class="filter-btn" aria-pressed="false">EA<span>{eaCount}</span></button>
        </div>
      </div>

      <!-- PINNED -->
      <div id="pinned-section" class={`catalog-group pinned-group${pinnedItems.length > 0 ? '' : ' hidden'}`}>
        <div class="catalog-label">
          <span>
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M16 3l5 5-1.5 1.5-1-.5-3.5 3.5.5 3.5-2 2-3.5-3.5L3 24l-1-1 6.5-8.5L5 11l2-2 3.5.5L14 6l-.5-1z"/></svg>
            ปักหมุด
          </span>
          <small>ดูสถานะและ README ก่อนใช้</small>
        </div>
        <div id="pinned-grid" class="resource-grid">
          {pinnedItems.map(item => (
            <div data-course-type={item.cardType} data-item-key={item.kind === 'ea' ? `ea:${item.id}` : `course:${item.id}`}>
              {item.kind === 'ea' ? (
                <a href={item.href} class="resource-card">
                  <div class="resource-card-visual ea">
                    <img src="/gdbasket-mark.png" alt="gdBasket" class="w-9 h-9 object-contain" />
                    <span>FREE</span>
                  </div>
                  <div class="resource-card-body">
                    <div class="resource-card-badges">
                      <span class="resource-type ea">EA</span>
                      {item.live && <span class="resource-live"><i></i> LIVE</span>}
                      {item.version && <span class="resource-version">{item.version}</span>}
                    </div>
                    <h3>{item.title}</h3>
                    <p>{item.description}</p>
                    <div class="resource-card-meta"><span></span><span>เปิด README</span></div>
                  </div>
                  <div class="resource-card-action" aria-hidden="true">
                    <svg class="w-[19px] h-[19px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M13 5l7 7-7 7" /></svg>
                  </div>
                </a>
              ) : (
                <button type="button" data-course-id={item.id} class="resource-card" aria-expanded="false">
                  <div class="resource-card-visual">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    <span>FREE</span>
                  </div>
                  <div class="resource-card-body">
                    <div class="resource-card-badges">
                      <span class="resource-type">คอร์สเรียน</span>
                    </div>
                    <h3>{item.title}</h3>
                    <p>{item.description}</p>
                    <div class="resource-card-meta"><span>{item.count} บท</span><span>ดูบทเรียน</span></div>
                  </div>
                  <div class="resource-card-action" aria-hidden="true">
                    <svg class="w-[19px] h-[19px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 9l6 6 6-6" /></svg>
                  </div>
                </button>
              )}
            </div>
          ))}
        </div>
      </div>

      <!-- REST -->
      <div id="rest-section" class={`catalog-group${restItems.length > 0 ? '' : ' hidden'}`}>
        <div class="catalog-label">
          <span>ทั้งหมด</span>
        </div>
        <div id="rest-grid" class="resource-grid">
          {restItems.map(item => (
            <div data-course-type={item.cardType} data-item-key={item.kind === 'ea' ? `ea:${item.id}` : `course:${item.id}`}>
              {item.kind === 'ea' ? (
                <a href={item.href} class="resource-card">
                  <div class="resource-card-visual ea">
                    <img src="/gdbasket-mark.png" alt="gdBasket" class="w-9 h-9 object-contain" />
                    <span>FREE</span>
                  </div>
                  <div class="resource-card-body">
                    <div class="resource-card-badges">
                      <span class="resource-type ea">EA</span>
                      {item.live && <span class="resource-live"><i></i> LIVE</span>}
                      {item.version && <span class="resource-version">{item.version}</span>}
                    </div>
                    <h3>{item.title}</h3>
                    <p>{item.description}</p>
                    <div class="resource-card-meta"><span></span><span>เปิด README</span></div>
                  </div>
                  <div class="resource-card-action" aria-hidden="true">
                    <svg class="w-[19px] h-[19px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M13 5l7 7-7 7" /></svg>
                  </div>
                </a>
              ) : (
                <button type="button" data-course-id={item.id} class="resource-card" aria-expanded="false">
                  <div class="resource-card-visual">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    <span>FREE</span>
                  </div>
                  <div class="resource-card-body">
                    <div class="resource-card-badges">
                      <span class="resource-type">คอร์สเรียน</span>
                    </div>
                    <h3>{item.title}</h3>
                    <p>{item.description}</p>
                    <div class="resource-card-meta"><span>{item.count} บท</span><span>ดูบทเรียน</span></div>
                  </div>
                  <div class="resource-card-action" aria-hidden="true">
                    <svg class="w-[19px] h-[19px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 9l6 6 6-6" /></svg>
                  </div>
                </button>
              )}
            </div>
          ))}
        </div>
      </div>

      <!-- Inline course content (toggle on resource-card click) -->
      {courses.map(course => {
        const courseLessons = renderedLessons.get(course.id) || [];
        const isMultiLesson = courseLessons.length > 1;
        return (
          <div id={`content-${course.id}`} class="course-preview hidden" data-course-content={course.id}>
            <div class="course-preview-head">
              <div>
                <span>COURSE OUTLINE</span>
                <h2>{course.data.title}</h2>
              </div>
              <button class="close-content" aria-label="ปิด">
                <svg class="w-[19px] h-[19px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
              </button>
            </div>

            {isMultiLesson && (
              <div class="lesson-tabs" data-course-tabs={course.id}>
                {courseLessons.map((lesson, i) => (
                  <button data-lesson-tab={`${course.id}/${lesson.id}`} class={`lesson-tab ${i === 0 ? 'active' : ''}`}>
                    <span>{String(i + 1).padStart(2, '0')}</span>{lesson.title}
                  </button>
                ))}
              </div>
            )}

            {courseLessons.map((lesson, i) => (
              <div data-lesson-content={`${course.id}/${lesson.id}`} class={`lesson-preview-copy ${i > 0 ? 'hidden' : ''}`}>
                {isMultiLesson && <div class="lesson-index">บทที่ {i + 1} / {courseLessons.length}</div>}
                {lesson.duration && <p class="text-[13px] text-gray-dark mb-4">{lesson.duration}</p>}
                <article class="prose prose-invert max-w-none
                  prose-headings:font-bold prose-headings:text-gray-light
                  prose-p:text-gray prose-p:leading-relaxed
                  prose-a:text-primary prose-a:no-underline hover:prose-a:underline
                  prose-strong:text-gray-light
                  prose-code:text-primary-light prose-code:bg-dark prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
                  prose-li:text-gray prose-ol:text-gray prose-ul:text-gray
                  prose-table:text-gray prose-th:text-gray-light prose-td:border-dark-border prose-th:border-dark-border">
                  <lesson.Content />
                </article>
              </div>
            ))}

            <BrokerCTA placement="end-of-lesson" />
          </div>
        );
      })}

      <div id="catalog-empty" class="catalog-empty hidden">ยังไม่มีรายการในหมวดนี้</div>

    </section>

  </div>
</Layout>

<script>
  // Course card toggle (course cards only — EA cards are <a> links)
  const courseCards = document.querySelectorAll<HTMLButtonElement>('button.resource-card');
  const courseContents = document.querySelectorAll<HTMLElement>('.course-preview');
  let activeCourse: string | null = null;

  function setCardExpanded(courseId: string, expanded: boolean) {
    document.querySelectorAll<HTMLButtonElement>(`button.resource-card[data-course-id="${courseId}"]`).forEach(card => {
      card.classList.toggle('expanded', expanded);
      card.setAttribute('aria-expanded', String(expanded));
      const meta = card.querySelector('.resource-card-meta span:last-child');
      if (meta) meta.textContent = expanded ? 'กำลังเปิด' : 'ดูบทเรียน';
      const chevron = card.querySelector('.resource-card-action svg');
      chevron?.classList.toggle('rotate', expanded);
    });
  }

  courseCards.forEach(card => {
    card.addEventListener('click', () => {
      const courseId = card.getAttribute('data-course-id')!;
      if (activeCourse === courseId) {
        document.getElementById(`content-${courseId}`)?.classList.add('hidden');
        setCardExpanded(courseId, false);
        activeCourse = null;
        return;
      }
      courseContents.forEach(c => c.classList.add('hidden'));
      if (activeCourse) setCardExpanded(activeCourse, false);
      const content = document.getElementById(`content-${courseId}`);
      if (content) {
        content.classList.remove('hidden');
        setCardExpanded(courseId, true);
        activeCourse = courseId;
        setTimeout(() => content.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
      }
    });
  });

  document.querySelectorAll('.close-content').forEach(btn => {
    btn.addEventListener('click', () => {
      const content = btn.closest('.course-preview') as HTMLElement;
      if (content) {
        content.classList.add('hidden');
        const courseId = content.getAttribute('data-course-content')!;
        setCardExpanded(courseId, false);
        activeCourse = null;
      }
    });
  });

  // Lesson tabs
  document.querySelectorAll<HTMLButtonElement>('.lesson-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const lessonKey = tab.getAttribute('data-lesson-tab')!;
      const courseId = lessonKey.split('/')[0];
      document.querySelectorAll<HTMLButtonElement>(`[data-lesson-tab^="${courseId}/"]`).forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      document.querySelectorAll<HTMLElement>(`[data-lesson-content^="${courseId}/"]`).forEach(body => body.classList.add('hidden'));
      document.querySelector<HTMLElement>(`[data-lesson-content="${lessonKey}"]`)?.classList.remove('hidden');
    });
  });

  // Filter
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const filterCards = document.querySelectorAll<HTMLElement>('[data-course-type]');
  const catalogEmpty = document.getElementById('catalog-empty');

  function applyFilter(filter: string) {
    filterBtns.forEach(b => {
      const on = b.getAttribute('data-filter') === filter;
      b.classList.toggle('active', on);
      b.setAttribute('aria-pressed', String(on));
    });
    let visibleCount = 0;
    filterCards.forEach(card => {
      const type = card.getAttribute('data-course-type');
      const match = filter === 'all' || type === filter || (filter === 'learn' && type === 'learn-tool');
      (card as HTMLElement).style.display = match ? '' : 'none';
      if (match) visibleCount++;
    });
    catalogEmpty?.classList.toggle('hidden', visibleCount > 0);
    // hide inline content while filtering
    courseContents.forEach(c => c.classList.add('hidden'));
    if (activeCourse) setCardExpanded(activeCourse, false);
    activeCourse = null;
  }

  filterBtns.forEach(btn => btn.addEventListener('click', () => applyFilter(btn.getAttribute('data-filter') || 'all')));

  // ?filter=ea -> auto-activate EA filter (nav "EA" link)
  const urlFilter = new URLSearchParams(window.location.search).get('filter');
  if (urlFilter === 'ea' || urlFilter === 'learn') applyFilter(urlFilter);

  // ── ปักหมุดจาก admin: ดึง content_pins (site_settings) มาจัดโซนใหม่ ──
  // fetch fail / ไม่มี pins = คง frontmatter เดิม (SSR default)
  function applyPins(pins: { key: string; order?: number }[]) {
    const pinnedGrid = document.getElementById('pinned-grid');
    const restGrid = document.getElementById('rest-grid');
    const pinnedSection = document.getElementById('pinned-section');
    const restSection = document.getElementById('rest-section');
    if (!pinnedGrid || !restGrid || !pinnedSection || !restSection) return;

    const orderMap = new Map(pins.map(p => [p.key, p.order ?? 999]));
    const wrappers = [...document.querySelectorAll<HTMLElement>('[data-item-key]')];
    const pinned = wrappers
      .filter(w => orderMap.has(w.dataset.itemKey!))
      .sort((a, b) => orderMap.get(a.dataset.itemKey!)! - orderMap.get(b.dataset.itemKey!)!);
    const rest = wrappers.filter(w => !orderMap.has(w.dataset.itemKey!));

    pinned.forEach(w => pinnedGrid.appendChild(w));
    rest.forEach(w => restGrid.appendChild(w));
    pinnedSection.classList.toggle('hidden', pinned.length === 0);
    restSection.classList.toggle('hidden', rest.length === 0);
  }

  const SUPA_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPA_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  if (SUPA_URL && SUPA_KEY) {
    (async () => {
      try {
        const res = await fetch(`${SUPA_URL}/rest/v1/site_settings?key=eq.content_pins&select=value`, {
          headers: { apikey: SUPA_KEY },
        });
        if (!res.ok) return;
        const rows = await res.json();
        const pins = rows?.[0]?.value; // JSONB -> array [{key, order}]
        if (Array.isArray(pins) && pins.length) applyPins(pins);
      } catch (e) { /* keep SSR frontmatter default */ }
    })();
  }
</script>
