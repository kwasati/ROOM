---
import Layout from '../layouts/Layout.astro';
import BrokerCTA from '../components/BrokerCTA.astro';
import { getCollection, render } from 'astro:content';
import { eaItems } from '../data/ea';

const courses = (await getCollection('courses')).sort((a, b) => a.data.order - b.data.order);
const allLessons = (await getCollection('lessons')).sort((a, b) => a.data.order - b.data.order);

const lessonCounts = new Map<string, number>();
for (const lesson of allLessons) {
  lessonCounts.set(lesson.data.course, (lessonCounts.get(lesson.data.course) || 0) + 1);
}
const totalLessons = allLessons.length;

// Pre-render lesson content (inline toggle for courses)
const renderedLessons = new Map<string, { id: string; title: string; duration?: string; order: number; course: string; Content: any }[]>();
for (const lesson of allLessons) {
  const { Content } = await render(lesson);
  const courseId = lesson.data.course;
  if (!renderedLessons.has(courseId)) renderedLessons.set(courseId, []);
  renderedLessons.get(courseId)!.push({
    id: lesson.id.split('/').pop()!,
    title: lesson.data.title,
    duration: lesson.data.duration,
    order: lesson.data.order,
    course: courseId,
    Content,
  });
}

// Normalize courses -> unified card shape
const courseItems = courses.map(c => ({
  kind: 'course' as const,
  id: c.id,
  title: c.data.title,
  description: c.data.description,
  count: lessonCounts.get(c.id) || 0,
  isLearn: c.data.courseType === 'learn',
  cardType: c.data.courseType, // 'learn' | 'learn-tool'
  pinned: c.data.pinned ?? false,
  pinOrder: c.data.pinOrder,
}));

type Item = (typeof eaItems)[number] | (typeof courseItems)[number];
const allItems: Item[] = [...eaItems, ...courseItems];

const pinnedItems = allItems
  .filter(i => i.pinned)
  .sort((a, b) => (a.pinOrder ?? 999) - (b.pinOrder ?? 999));
const restItems = allItems.filter(i => !i.pinned);
---

<Layout title="Room — เรียน+เทรดฟรี | IntensiveTrader">
  <section class="py-10">
    <div class="max-w-[1100px] mx-auto px-5">

      <!-- HERO -->
      <div class="flex items-start justify-between gap-5 flex-wrap max-md:flex-col max-md:items-center max-md:text-center">
        <div>
          <h1 class="text-[30px] max-md:text-[24px] font-bold text-gray-light leading-tight mb-2">
            เรียน<span class="text-primary">+</span>เทรด<br><span class="text-secondary">ฟรีทั้งหมด</span>
          </h1>
          <p class="text-[15px] text-gray max-w-[520px] leading-relaxed">
            คอร์สมือใหม่ + เครื่องมือเทรด (EA) สำหรับ MT5 — โหลดใช้ได้เลย ไม่มีค่าใช้จ่าย ไม่มีเงื่อนไข
          </p>
        </div>
        <div class="flex gap-5 items-center mt-2 max-md:mt-4">
          <div class="text-center">
            <div class="text-[22px] font-bold text-secondary">{courses.length}</div>
            <div class="text-[11px] text-gray-dark">คอร์ส</div>
          </div>
          <div class="text-center">
            <div class="text-[22px] font-bold text-secondary">{eaItems.length}</div>
            <div class="text-[11px] text-gray-dark">EA</div>
          </div>
          <div class="text-center">
            <div class="text-[22px] font-bold text-secondary">{totalLessons}</div>
            <div class="text-[11px] text-gray-dark">บทเรียน</div>
          </div>
        </div>
      </div>

      <!-- FILTERS -->
      <div class="flex gap-1.5 mt-6 flex-wrap max-md:justify-center" id="course-filter">
        <button data-filter="all" class="filter-btn px-4 py-[7px] rounded-full text-[13px] font-medium transition-colors bg-primary text-white border border-primary cursor-pointer">ทั้งหมด</button>
        <button data-filter="learn" class="filter-btn px-4 py-[7px] rounded-full text-[13px] font-medium transition-colors bg-transparent text-gray-dark border border-dark-border hover:border-primary hover:text-primary cursor-pointer">คอร์สเรียน</button>
        <button data-filter="ea" class="filter-btn px-4 py-[7px] rounded-full text-[13px] font-medium transition-colors bg-transparent text-gray-dark border border-dark-border hover:border-primary hover:text-primary cursor-pointer">EA</button>
      </div>

      <!-- PINNED -->
      <div id="pinned-section" class={pinnedItems.length > 0 ? 'mt-7' : 'mt-7 hidden'}>
          <div class="flex items-center gap-2 mb-3">
            <svg class="w-4 h-4 text-secondary" fill="currentColor" viewBox="0 0 24 24"><path d="M16 3l5 5-1.5 1.5-1-.5-3.5 3.5.5 3.5-2 2-3.5-3.5L3 24l-1-1 6.5-8.5L5 11l2-2 3.5.5L14 6l-.5-1z"/></svg>
            <span class="text-[11px] text-gray-dark uppercase tracking-[1.5px] font-semibold">ปักหมุด</span>
          </div>
          <div id="pinned-grid" class="grid grid-cols-2 max-md:grid-cols-1 gap-3.5">
            {pinnedItems.map(item => (
              <div data-course-type={item.cardType} data-item-key={item.kind === 'ea' ? `ea:${item.id}` : `course:${item.id}`}>
                {item.kind === 'ea' ? (
                  <a href={item.href} class="course-card group flex w-full text-left bg-dark-card rounded-[14px] border border-primary/40 hover:border-primary transition-all cursor-pointer overflow-hidden pixel-shadow">
                    <div class="w-[150px] max-md:w-[110px] shrink-0 flex items-center justify-center bg-gradient-to-br from-stone-900 to-stone-800 relative">
                      <span class="pixel text-primary text-[13px] opacity-80">EA</span>
                      <span class="absolute top-2.5 right-2.5 bg-green text-black text-[10px] font-bold px-2 py-0.5 rounded">FREE</span>
                    </div>
                    <div class="p-4 flex-1">
                      <div class="flex items-center gap-2 mb-1.5 flex-wrap">
                        <span class="text-[10px] font-semibold px-2 py-0.5 rounded bg-primary/15 text-primary">EA</span>
                        {item.live && <span class="text-[10px] font-semibold px-2 py-0.5 rounded bg-green/10 text-green">LIVE</span>}
                        <span class="text-[11px] text-gray-dark">{item.version}</span>
                      </div>
                      <div class="text-[16px] font-semibold group-hover:text-primary transition-colors mb-1">{item.title}</div>
                      <div class="text-[13px] text-gray line-clamp-2 leading-snug">{item.description}</div>
                    </div>
                  </a>
                ) : (
                  <button data-course-id={item.id} class="course-card group flex w-full text-left bg-dark-card rounded-[14px] border border-primary/40 hover:border-primary transition-all cursor-pointer overflow-hidden pixel-shadow">
                    <div class="w-[150px] max-md:w-[110px] shrink-0 flex items-center justify-center bg-gradient-to-br from-stone-900 to-stone-800 relative">
                      <svg class="w-9 h-9 opacity-30 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                      <span class="absolute top-2.5 right-2.5 bg-green text-black text-[10px] font-bold px-2 py-0.5 rounded">FREE</span>
                    </div>
                    <div class="p-4 flex-1">
                      <div class="flex items-center gap-2 mb-1.5">
                        <span class="text-[10px] font-semibold px-2 py-0.5 rounded bg-primary/15 text-primary">คอร์สเรียน</span>
                        <span class="text-[11px] text-gray-dark">{item.count} บท</span>
                      </div>
                      <div class="text-[16px] font-semibold group-hover:text-primary transition-colors mb-1">{item.title}</div>
                      <div class="text-[13px] text-gray line-clamp-2 leading-snug">{item.description}</div>
                    </div>
                  </button>
                )}
              </div>
            ))}
          </div>
        </div>

      <!-- ALL (non-pinned) -->
      <div id="rest-section" class={restItems.length > 0 ? 'mt-8' : 'mt-8 hidden'}>
          <div class="text-[11px] text-gray-dark uppercase tracking-[1.5px] font-semibold mb-3">ทั้งหมด</div>
          <div id="rest-grid" class="grid grid-cols-2 max-md:grid-cols-1 gap-3.5">
            {restItems.map(item => (
              <div data-course-type={item.cardType} data-item-key={item.kind === 'ea' ? `ea:${item.id}` : `course:${item.id}`}>
                {item.kind === 'ea' ? (
                  <a href={item.href} class="course-card group flex w-full text-left bg-dark-card rounded-[14px] border border-dark-border hover:border-primary transition-all cursor-pointer overflow-hidden">
                    <div class="w-[150px] max-md:w-[110px] shrink-0 flex items-center justify-center bg-gradient-to-br from-stone-900 to-stone-800 relative">
                      <span class="pixel text-primary text-[13px] opacity-80">EA</span>
                      <span class="absolute top-2.5 right-2.5 bg-green text-black text-[10px] font-bold px-2 py-0.5 rounded">FREE</span>
                    </div>
                    <div class="p-4 flex-1">
                      <div class="flex items-center gap-2 mb-1.5 flex-wrap">
                        <span class="text-[10px] font-semibold px-2 py-0.5 rounded bg-primary/15 text-primary">EA</span>
                        {item.live && <span class="text-[10px] font-semibold px-2 py-0.5 rounded bg-green/10 text-green">LIVE</span>}
                        <span class="text-[11px] text-gray-dark">{item.version}</span>
                      </div>
                      <div class="text-[16px] font-semibold group-hover:text-primary transition-colors mb-1">{item.title}</div>
                      <div class="text-[13px] text-gray line-clamp-2 leading-snug">{item.description}</div>
                    </div>
                  </a>
                ) : (
                  <button data-course-id={item.id} class="course-card group flex w-full text-left bg-dark-card rounded-[14px] border border-dark-border hover:border-primary transition-all cursor-pointer overflow-hidden">
                    <div class="w-[150px] max-md:w-[110px] shrink-0 flex items-center justify-center bg-gradient-to-br from-stone-900 to-stone-800 relative">
                      <svg class="w-9 h-9 opacity-30 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                      <span class="absolute top-2.5 right-2.5 bg-green text-black text-[10px] font-bold px-2 py-0.5 rounded">FREE</span>
                    </div>
                    <div class="p-4 flex-1">
                      <div class="flex items-center gap-2 mb-1.5">
                        <span class="text-[10px] font-semibold px-2 py-0.5 rounded bg-primary/15 text-primary">คอร์สเรียน</span>
                        <span class="text-[11px] text-gray-dark">{item.count} บท</span>
                      </div>
                      <div class="text-[16px] font-semibold group-hover:text-primary transition-colors mb-1">{item.title}</div>
                      <div class="text-[13px] text-gray line-clamp-2 leading-snug">{item.description}</div>
                    </div>
                  </button>
                )}
              </div>
            ))}
          </div>
        </div>

      <!-- Inline course content (toggle on course-card click) -->
      {courses.map(course => {
        const courseLessons = renderedLessons.get(course.id) || [];
        const isMultiLesson = courseLessons.length > 1;
        return (
          <div id={`content-${course.id}`} class="course-content hidden mt-6" data-course-content={course.id}>
            <div class="bg-dark-card border border-dark-border rounded-[14px] p-6 max-md:p-4">
              <div class="flex items-center justify-between mb-5">
                <h2 class="text-[20px] max-md:text-[18px] font-bold text-gray-light">{course.data.title}</h2>
                <button class="close-content text-gray-dark hover:text-gray-light transition-colors p-1 cursor-pointer" aria-label="ปิด">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
              </div>

              {isMultiLesson && (
                <div class="lesson-tabs flex gap-1.5 mb-6 flex-wrap" data-course-tabs={course.id}>
                  {courseLessons.map((lesson, i) => (
                    <button data-lesson-tab={`${course.id}/${lesson.id}`} class={`lesson-tab px-4 py-2 rounded-full text-[13px] font-medium transition-colors cursor-pointer ${i === 0 ? 'bg-primary text-white border border-primary' : 'bg-transparent text-gray-dark border border-dark-border hover:border-primary hover:text-primary'}`}>
                      {i + 1}. {lesson.title}
                    </button>
                  ))}
                </div>
              )}

              {courseLessons.map((lesson, i) => (
                <div data-lesson-content={`${course.id}/${lesson.id}`} class={`lesson-body ${i > 0 ? 'hidden' : ''}`}>
                  {lesson.duration && <p class="text-[13px] text-gray-dark mb-4">{lesson.duration}</p>}
                  <article class="prose prose-invert max-w-none
                    prose-headings:font-bold prose-headings:text-gray-light
                    prose-p:text-gray prose-p:leading-relaxed
                    prose-a:text-primary prose-a:no-underline hover:prose-a:underline
                    prose-strong:text-gray-light
                    prose-code:text-primary-light prose-code:bg-dark prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
                    prose-li:text-gray prose-ol:text-gray prose-ul:text-gray
                    prose-table:text-gray prose-th:text-gray-light prose-td:border-dark-border prose-th:border-dark-border">
                    <lesson.Content />
                  </article>
                </div>
              ))}

              <BrokerCTA placement="end-of-lesson" />
            </div>
          </div>
        );
      })}

    </div>
  </section>
</Layout>

<script>
  // Course card toggle (course cards only — EA cards are <a> links)
  const courseCards = document.querySelectorAll<HTMLButtonElement>('button.course-card');
  const courseContents = document.querySelectorAll<HTMLElement>('.course-content');
  let activeCourse: string | null = null;

  function deactivateCard(courseId: string) {
    document.querySelectorAll<HTMLButtonElement>(`button.course-card[data-course-id="${courseId}"]`).forEach(c => {
      c.classList.remove('border-primary');
    });
  }

  courseCards.forEach(card => {
    card.addEventListener('click', () => {
      const courseId = card.getAttribute('data-course-id')!;
      if (activeCourse === courseId) {
        document.getElementById(`content-${courseId}`)?.classList.add('hidden');
        deactivateCard(courseId);
        activeCourse = null;
        return;
      }
      courseContents.forEach(c => c.classList.add('hidden'));
      const content = document.getElementById(`content-${courseId}`);
      if (content) {
        content.classList.remove('hidden');
        document.querySelectorAll<HTMLButtonElement>(`button.course-card[data-course-id="${courseId}"]`).forEach(c => c.classList.add('border-primary'));
        activeCourse = courseId;
        setTimeout(() => content.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
      }
    });
  });

  document.querySelectorAll('.close-content').forEach(btn => {
    btn.addEventListener('click', () => {
      const content = btn.closest('.course-content') as HTMLElement;
      if (content) {
        content.classList.add('hidden');
        deactivateCard(content.getAttribute('data-course-content')!);
        activeCourse = null;
      }
    });
  });

  // Lesson tabs
  document.querySelectorAll<HTMLButtonElement>('.lesson-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const lessonKey = tab.getAttribute('data-lesson-tab')!;
      const courseId = lessonKey.split('/')[0];
      document.querySelectorAll<HTMLButtonElement>(`[data-lesson-tab^="${courseId}/"]`).forEach(t => {
        t.classList.remove('bg-primary', 'text-white', 'border-primary');
        t.classList.add('bg-transparent', 'text-gray-dark', 'border-dark-border');
      });
      tab.classList.remove('bg-transparent', 'text-gray-dark', 'border-dark-border');
      tab.classList.add('bg-primary', 'text-white', 'border-primary');
      document.querySelectorAll<HTMLElement>(`[data-lesson-content^="${courseId}/"]`).forEach(body => body.classList.add('hidden'));
      document.querySelector<HTMLElement>(`[data-lesson-content="${lessonKey}"]`)?.classList.remove('hidden');
    });
  });

  // Filter
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const filterCards = document.querySelectorAll<HTMLElement>('[data-course-type]');

  function applyFilter(filter: string) {
    filterBtns.forEach(b => {
      const on = b.getAttribute('data-filter') === filter;
      b.classList.toggle('bg-primary', on);
      b.classList.toggle('text-white', on);
      b.classList.toggle('border-primary', on);
      b.classList.toggle('bg-transparent', !on);
      b.classList.toggle('text-gray-dark', !on);
      b.classList.toggle('border-dark-border', !on);
    });
    filterCards.forEach(card => {
      const type = card.getAttribute('data-course-type');
      const match = filter === 'all' || type === filter || (filter === 'learn' && type === 'learn-tool');
      (card as HTMLElement).style.display = match ? '' : 'none';
    });
    // hide inline content while filtering
    courseContents.forEach(c => c.classList.add('hidden'));
    courseCards.forEach(c => c.classList.remove('border-primary'));
    activeCourse = null;
  }

  filterBtns.forEach(btn => btn.addEventListener('click', () => applyFilter(btn.getAttribute('data-filter') || 'all')));

  // ?filter=ea -> auto-activate EA filter (nav "EA" link)
  const urlFilter = new URLSearchParams(window.location.search).get('filter');
  if (urlFilter === 'ea' || urlFilter === 'learn') applyFilter(urlFilter);

  // ── ปักหมุดจาก admin: ดึง content_pins (site_settings) มาจัดโซนใหม่ ──
  // fetch fail / ไม่มี pins = คง frontmatter เดิม (SSR default)
  function setPinnedStyle(wrapper: HTMLElement, on: boolean) {
    const card = wrapper.querySelector('.course-card');
    if (!card) return;
    card.classList.toggle('border-primary/40', on);
    card.classList.toggle('pixel-shadow', on);
    card.classList.toggle('border-dark-border', !on);
  }

  function applyPins(pins: { key: string; order?: number }[]) {
    const pinnedGrid = document.getElementById('pinned-grid');
    const restGrid = document.getElementById('rest-grid');
    const pinnedSection = document.getElementById('pinned-section');
    const restSection = document.getElementById('rest-section');
    if (!pinnedGrid || !restGrid || !pinnedSection || !restSection) return;

    const orderMap = new Map(pins.map(p => [p.key, p.order ?? 999]));
    const wrappers = [...document.querySelectorAll<HTMLElement>('[data-item-key]')];
    const pinned = wrappers
      .filter(w => orderMap.has(w.dataset.itemKey!))
      .sort((a, b) => orderMap.get(a.dataset.itemKey!)! - orderMap.get(b.dataset.itemKey!)!);
    const rest = wrappers.filter(w => !orderMap.has(w.dataset.itemKey!));

    pinned.forEach(w => { setPinnedStyle(w, true); pinnedGrid.appendChild(w); });
    rest.forEach(w => { setPinnedStyle(w, false); restGrid.appendChild(w); });
    pinnedSection.classList.toggle('hidden', pinned.length === 0);
    restSection.classList.toggle('hidden', rest.length === 0);
  }

  const SUPA_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPA_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  if (SUPA_URL && SUPA_KEY) {
    (async () => {
      try {
        const res = await fetch(`${SUPA_URL}/rest/v1/site_settings?key=eq.content_pins&select=value`, {
          headers: { apikey: SUPA_KEY },
        });
        if (!res.ok) return;
        const rows = await res.json();
        const pins = rows?.[0]?.value; // JSONB -> array [{key, order}]
        if (Array.isArray(pins) && pins.length) applyPins(pins);
      } catch (e) { /* keep SSR frontmatter default */ }
    })();
  }
</script>
