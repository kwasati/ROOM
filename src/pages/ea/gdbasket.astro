const MAIN = 'https://intensivetrader.com';
const JOURNAL = 'https://journal.intensivetrader.com/';
const DL_LATEST = `${MAIN}/d/gdbasket`; // ปุ่มหลัก — redirect ชี้ไฟล์รุ่นล่าสุด v3.02 (publish/releases/v3.02/gdBasket_v3.02.ex5)
const DL_V202 = `${MAIN}/d/gdbasket-v202`;
const DL_V201 = `${MAIN}/d/gdbasket-v201`;
const DL_V200 = `${MAIN}/d/gdbasket-v200`;
const DL_V137 = `${MAIN}/d/gdbasket-v137`;
const DL_V118 = `${MAIN}/d/gdbasket-v118`;
const XM_AFF = 'https://affs.click/jih0m';
const XM_CODE = 'KWASATI';
const VPS_AFF = 'https://bit.ly/MTCloudVPS';
const COPYTRADE_URL = 'https://social.tp-redirect.com/s/0mYnzepR';

// Myfxbook — ดึงทุกพอร์ต live จาก /api/myfxbook.json ตอน build + fallback ต่อบัญชีกันพัง
// client script ท้ายไฟล์ refresh ค่าสดตอน runtime + clone การ์ดเพิ่มเองเมื่อ API คายพอร์ตใหม่ ไม่ต้องแก้ไฟล์นี้อีก
type MfbCard = {
  id: string; name: string; label: string; url: string | null; newNote: string | null;
  gain: string | null; absGain: string | null; monthly: string | null; drawdown: string | null; balance: string | null;
};
const mfbSlug = (s: string) => (s || 'account').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const mfbFallback: MfbCard[] = [
  { id: '12090186', name: 'gdbasket-xs', label: 'พอร์ต 1', url: 'https://www.myfxbook.com/members/kwasati/gdbasket-xs/12090186', newNote: null, gain: '53.40', absGain: '53.45', monthly: '53.40', drawdown: '18.16', balance: '460.36' },
  { id: '12105756', name: 'gdbasket lx', label: 'พอร์ต 2', url: 'https://www.myfxbook.com/members/kwasati/gdbasket-lx/12105756', newNote: 'พอร์ตใหม่ เริ่ม 2026-07', gain: null, absGain: null, monthly: null, drawdown: null, balance: null },
];
let mfbCards: MfbCard[] = mfbFallback;
try {
  const raw = await fetch('https://www.intensivetrader.com/api/myfxbook.json').then((r) => r.json());
  // API รุ่นเก่าคาย object พอร์ตเดียว (ไม่มี id/name) — แปลงเป็น array โดยถือเป็นพอร์ต 1; รุ่นใหม่คาย array ทุกพอร์ต live
  const accounts = Array.isArray(raw) ? raw : (raw && raw.gain != null ? [{ id: mfbFallback[0].id, name: mfbFallback[0].name, ...raw }] : []);
  if (accounts.length > 0) {
    const f = (n: unknown) => (n == null ? null : Number(n).toFixed(2));
    const toCard = (acc: any, base: MfbCard): MfbCard => ({
      ...base,
      id: String(acc.id),
      name: acc.name || base.name,
      url: `https://www.myfxbook.com/members/kwasati/${mfbSlug(acc.name || base.name)}/${acc.id}`,
      newNote: null,
      gain: f(acc.gain), absGain: f(acc.absGain), monthly: f(acc.monthly), drawdown: f(acc.drawdown), balance: f(acc.balance),
    });
    const used = new Set<string>();
    mfbCards = mfbFallback.map((fb) => {
      const acc = accounts.find((a: any) => String(a.id) === fb.id || (a.name || '').toLowerCase() === fb.name.toLowerCase());
      if (!acc) return fb; // fallback ต่อบัญชี — API ยังไม่คืนพอร์ตนี้
      used.add(String(acc.id));
      return toCard(acc, fb);
    });
    // พอร์ตใหม่ที่ยังไม่รู้จัก — ต่อท้ายเป็นการ์ดเพิ่ม
    for (const acc of accounts) {
      if (!used.has(String(acc.id))) mfbCards.push(toCard(acc, { id: '', name: '', label: `พอร์ต ${mfbCards.length + 1}`, url: null, newNote: null, gain: null, absGain: null, monthly: null, drawdown: null, balance: null }));
    }
  }
} catch (e) { /* ใช้ fallback */ }

const features = [
