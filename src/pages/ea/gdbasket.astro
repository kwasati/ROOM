        <div class="flex items-center gap-2 mb-4">
          <img src={`${MAIN}/profile.jpg`} class="w-8 h-8 rounded-full bg-dark-border" alt="" />
          <div><div class="text-sm text-gray-light">IntensiveTrader</div><div class="text-xs text-gray-dark">Kittitat Wasati</div></div>
        </div>
        <a href="https://www.facebook.com/IntensiveTraderArt" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 border border-dark-border text-gray-light hover:border-primary px-4 py-2 rounded-lg text-sm transition-colors">
          <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          แจ้ง Bug / ติดต่อ
        </a>
      </div>
    </aside>

  </div>
</div>

<style>
  .install-path {
    display: inline-block;
    background: var(--color-dark);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-family: 'Courier New', monospace;
    font-size: 0.78rem;
    color: var(--color-secondary);
  }
</style>

<script>
  const SUPA = import.meta.env.PUBLIC_SUPABASE_URL;
  const KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  if (SUPA && KEY) {
    const headers = { apikey: KEY, Authorization: `Bearer ${KEY}` };
    Promise.all([
      fetch(`${SUPA}/rest/v1/baskets?select=pnl_usd,account_login&limit=100000`, { headers }).then((r) => r.json()),
      fetch(`${SUPA}/rest/v1/accounts?select=login,display_name`, { headers }).then((r) => r.json()).catch(() => []),
    ])
      .then(([rows, accs]) => {
        if (!Array.isArray(rows) || rows.length === 0) return;
        const names = {};
        if (Array.isArray(accs)) for (const a of accs) names[String(a.login)] = a.display_name || String(a.login);
        const money = (n) => (n >= 0 ? '+$' : '-$') + Math.abs(Math.round(n)).toLocaleString();
        const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
        const render = (login) => {
          const sel = login == null ? rows : rows.filter((b) => String(b.account_login) === login);
          let sum = 0, win = 0;
          for (const b of sel) { const p = Number(b.pnl_usd) || 0; sum += p; if (p >= 0) win++; }
          const wr = sel.length ? Math.round((win / sel.length) * 100) : 0;
          const pnlEl = document.getElementById('tj-pnl');
          if (pnlEl) { pnlEl.textContent = money(sum); pnlEl.className = 'text-[17px] font-bold ' + (sum >= 0 ? 'text-green' : 'text-primary'); }
          set('tj-wr', wr + '%');
          set('tj-ct', String(sel.length));
        };
        // toggle รวม/ต่อพอร์ต — โชว์เมื่อมีมากกว่า 1 พอร์ตจริงในข้อมูล (label จาก accounts.display_name, fallback เลขบัญชี)
        const logins = [...new Set(rows.map((b) => (b.account_login == null ? '' : String(b.account_login))).filter(Boolean))].sort();
        const wrap = document.getElementById('tj-toggle');
        if (wrap && logins.length > 1) {
          const OFF = 'flex-1 rounded-md py-1 cursor-pointer bg-transparent text-gray-dark text-[11px] font-semibold border-0';
          const ON = 'flex-1 rounded-md py-1 cursor-pointer bg-primary text-white text-[11px] font-semibold border-0';
          const mk = (label, login) => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.textContent = label;
            btn.className = OFF;
            btn.addEventListener('click', () => {
              wrap.querySelectorAll('button').forEach((b) => { b.className = OFF; });
              btn.className = ON;
              render(login);
            });
            wrap.appendChild(btn);
            return btn;
          };
          mk('รวม', null).className = ON;
          logins.forEach((l) => mk(names[l] || l, l));
          wrap.classList.remove('hidden');
          wrap.classList.add('flex');
        }
        render(null);
      })
      .catch(() => {});
  }
  // Myfxbook — API คาย array ทุกพอร์ต live; การ์ด SSR (มี 2 ใบตอน build) reuse ตามลำดับ พอร์ตเกินจากนั้น clone เพิ่มเอง
  fetch('https://www.intensivetrader.com/api/myfxbook.json')
    .then((r) => r.json())
    .then((raw) => {
      const list = document.getElementById('mfb-list');
      const ssrCards = list ? Array.from(list.querySelectorAll('[data-mfb-id]')) : [];
      const template = ssrCards[0];
      if (!list || !template) return;
      // API รุ่นเก่าคาย object พอร์ตเดียว (ไม่มี id/name) — ถือเป็นพอร์ต 1 (การ์ด SSR ใบแรก)
      let accounts = raw;
      if (!Array.isArray(accounts)) {
        if (!accounts || accounts.gain == null) return;
        const lbl = template.querySelector('.mfb-label');
        accounts = [{ id: template.getAttribute('data-mfb-id'), name: lbl ? (lbl.textContent || '').split(' · ')[0] : '', ...accounts }];
      }
      if (accounts.length === 0) return;
      const slugify = (s) => (s || 'account').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
      accounts.forEach((acc, i) => {
        // หาการ์ดตาม id ก่อน — ไม่เจอ (พอร์ตใหม่ที่ fallback ตอน build) ใช้การ์ด SSR ตามลำดับ — เกินจำนวน SSR ค่อย clone
        let card = list.querySelector(`[data-mfb-id="${acc.id}"]`) || ssrCards[i];
        let isNew = false;
        if (!card) {
          card = template.cloneNode(true);
          list.appendChild(card);
          isNew = true;
        }
        card.setAttribute('data-mfb-id', String(acc.id));
        const set = (sel, v, pre, suf) => { const el = card.querySelector(sel); if (el && v != null) el.textContent = (pre || '') + v + (suf || ''); };
        set('.mfb-gain', acc.gain, '+', '%');
        set('.mfb-absgain', acc.absGain, '+', '%');
        set('.mfb-monthly', acc.monthly, '', '%');
        set('.mfb-dd', acc.drawdown, '', '%');
        set('.mfb-balance', acc.balance, '$', '');
        const label = card.querySelector('.mfb-label');
        if (label && acc.name) label.textContent = `${acc.name} · พอร์ต ${i + 1}`;
        // มีตัวเลขจริงแล้ว — เอา note "พอร์ตใหม่ รอผูก" ออก
        if (acc.gain != null) { const note = card.querySelector('.mfb-new-note'); if (note) note.remove(); }
        // การ์ด SSR ที่มีลิงก์จริงอยู่แล้วคงเดิม — การ์ด clone/การ์ด fallback (href="#") คำนวณลิงก์เอง
        const link = card.querySelector('.mfb-link');
        if (link && (isNew || link.getAttribute('href') === '#')) link.href = `https://www.myfxbook.com/members/kwasati/${slugify(acc.name)}/${acc.id}`;
      });
    })
    .catch(() => {});
  document.querySelectorAll('.copy-code').forEach((btn) => {
    btn.addEventListener('click', () => {
      const code = btn.getAttribute('data-copy') || '';
      if (navigator.clipboard) navigator.clipboard.writeText(code);
      const prev = btn.textContent;
      btn.textContent = 'คัดลอกแล้ว!';
      setTimeout(() => { btn.textContent = prev; }, 1500);
    });
  });
</script>
</Layout>
