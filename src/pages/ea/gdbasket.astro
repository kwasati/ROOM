              <tr><td>1.5 เท่า</td><td>15,000</td><td class="negative">87%</td><td>26</td><td>4</td><td>1</td></tr>
              <tr><td>2 เท่า</td><td>20,000</td><td class="positive">100%</td><td>29</td><td>0</td><td>2</td></tr>
              <tr><td>3 เท่า</td><td>30,000</td><td class="positive">100%</td><td>29</td><td>0</td><td>2</td></tr>
              <tr><td>5 เท่า</td><td>50,000</td><td class="positive">100%</td><td>29</td><td>0</td><td>2</td></tr>
            </tbody>
          </table>
        </div>
        <p style="margin:0;">เอาทุนเข้าไปแค่เท่าทุนต่อรอบ (10,000) เจอจังหวะร้ายมีโอกาสตาย 13% ก่อนได้กำไรรอบแรก — แต่ถ้ากันทุนไว้ <strong class="positive">2 เท่าของทุนต่อรอบ (20,000) ขึ้นไป ไม่เคยตายเลยในข้อมูลทั้งหมด</strong> ไม่ว่าจะเริ่มจังหวะไหน ทุน 1x กับ 1.5x รอด % เท่ากันเป๊ะ — แปลว่าเบาะ 5,000 ที่เพิ่มจาก 1x ไป 1.5x ยังไม่พอกันตาย ต้องข้ามไปถึง 2x ถึงจะเห็นผลจริง</p>
      </div>

    </div>
  </div>
</div>

<style>
  .install-path {
    display: inline-block;
    background: var(--color-dark);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-family: 'Courier New', monospace;
    font-size: 0.78rem;
    color: var(--color-secondary);
  }

  /* KPI row VELOCE — adapt จาก .engine-readout dl (4 คอลัมน์ ยืนเดี่ยวได้) */
  .kpi-row { margin: 6px 0 27px; display: grid; grid-template-columns: repeat(4, 1fr); border-top: 1px solid var(--color-dark-border); border-left: 1px solid var(--color-dark-border); border-radius: 8px; overflow: hidden; }
  .kpi-row > div { min-width: 0; display: flex; flex-direction: column-reverse; justify-content: center; padding: 16px 10px; border-right: 1px solid var(--color-dark-border); border-bottom: 1px solid var(--color-dark-border); text-align: center; background: var(--color-dark-card); }
  .kpi-row dt { color: var(--color-gray-dark); font-size: 9.5px; line-height: 1.4; margin-top: 5px; }
  .kpi-row dd { margin: 0; color: var(--color-green); font-size: 18px; font-weight: 800; }
  .kpi-row dd.danger { color: var(--color-primary-light); }
  @media (max-width: 600px) {
    .kpi-row { grid-template-columns: repeat(2, 1fr) !important; }
  }

  /* popup "ดูสถิติเต็ม" — overlay ใหม่ (backdrop-blur เดียวกับ .glass-dark) + กล่องเนื้อหายืมค่าจาก .readme-card/.course-preview */
  .stats-modal-overlay { position: fixed; inset: 0; z-index: 300; display: none; align-items: center; justify-content: center; padding: 20px; background: rgba(0,0,0,.75); backdrop-filter: blur(6px); }
  .stats-modal-overlay.open { display: flex; }
  .stats-modal { width: 100%; max-width: 880px; max-height: 88vh; overflow-y: auto; background: var(--color-dark-card); border: 1px solid var(--color-dark-border); border-radius: 9px; box-shadow: 8px 8px 0 rgba(0,0,0,.18); scrollbar-width: thin; scrollbar-color: var(--color-dark-border) transparent; }
  .stats-modal::-webkit-scrollbar { width: 8px; }
  .stats-modal::-webkit-scrollbar-track { background: transparent; }
  .stats-modal::-webkit-scrollbar-thumb { background: var(--color-dark-border); border-radius: 999px; }
  .stats-modal::-webkit-scrollbar-thumb:hover { background: var(--color-primary); }
  .stats-modal-head { position: sticky; top: 0; z-index: 2; display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; padding: 18px clamp(16px, 3vw, 28px); background: var(--color-dark-card); border-bottom: 1px solid var(--color-dark-border); }
  .stats-modal-head span.eyebrow { display: block; color: var(--color-primary-light); font-size: 10px; letter-spacing: .16em; }
  .stats-modal-head h2 { margin: 5px 0 0; font-size: 19px; font-weight: 700; color: var(--color-gray-light); border: 0; padding: 0; }
  .stats-modal-head p { margin: 4px 0 0; color: var(--color-gray-dark); font-size: 11px; }
  .stats-modal-close { width: 38px; height: 38px; flex: 0 0 auto; display: grid; place-items: center; color: var(--color-gray); background: transparent; border: 1px solid var(--color-dark-border); border-radius: 7px; cursor: pointer; }
  .stats-modal-close:hover { color: var(--color-gray-light); border-color: var(--color-primary); }
  .stats-modal-body { padding: 20px clamp(16px, 3vw, 28px) 30px; color: var(--color-gray); font-size: 13px; line-height: 1.75; }
  .stats-modal-body h3 { margin: 30px 0 12px; padding-bottom: 7px; color: var(--color-gray-light); border-bottom: 1px solid var(--color-dark-border); font-size: 14px; }
  .stats-modal-body h3:first-child { margin-top: 0; }
  .stats-modal-body p { margin: 0 0 12px; }
  .stats-modal-body strong { color: var(--color-gray-light); }
  @media (max-width: 600px) {
    .stats-modal-overlay { padding: 0; }
    .stats-modal { max-width: 100%; max-height: 100vh; height: 100vh; border-radius: 0; }
  }
</style>

<script>
  // popup "ดูสถิติเต็ม" — เปิด/ปิด (ปุ่ม X / คลิก overlay / กด Esc)
  function openStatsModal(){
    var overlay = document.getElementById('stats-modal-overlay');
    if (!overlay) return;
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeStatsModal(){
    var overlay = document.getElementById('stats-modal-overlay');
    if (!overlay) return;
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeStatsModal();
  });
  window.openStatsModal = openStatsModal;
  window.closeStatsModal = closeStatsModal;

  // fix sidebar sticky — top คำนวณจากความสูงจริง แทนค่าตายตัว
  (function () {
    var sidebar = document.getElementById('repo-sidebar');
    if (!sidebar) return;
    var mobileQuery = window.matchMedia('(max-width: 820px)');

    function reflow() {
      if (mobileQuery.matches) {
        // ≤820px = position:static ใน CSS อยู่แล้ว — ไม่ต้องยุ่ง var
        return;
      }
      var margin = 24; // เผื่อขอบล่างจอ
      var baseTop = 96; // ค่าตั้งต้นเดิมของ .repo-sidebar
      var h = sidebar.offsetHeight;
      var vh = window.innerHeight;
      var top = Math.min(baseTop, vh - h - margin);
      sidebar.style.setProperty('--sb-top', top + 'px');
    }

    window.addEventListener('load', reflow);
    window.addEventListener('resize', reflow);
    if (window.ResizeObserver) {
      new ResizeObserver(reflow).observe(sidebar);
    }
    reflow();
  })();

  const SUPA = import.meta.env.PUBLIC_SUPABASE_URL;
  const KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  if (SUPA && KEY) {
    const headers = { apikey: KEY, Authorization: `Bearer ${KEY}` };
    Promise.all([
      fetch(`${SUPA}/rest/v1/baskets?select=pnl_usd,account_login&limit=100000`, { headers }).then((r) => r.json()),
      fetch(`${SUPA}/rest/v1/accounts?select=login,display_name`, { headers }).then((r) => r.json()).catch(() => []),
    ])
      .then(([rows, accs]) => {
        if (!Array.isArray(rows) || rows.length === 0) return;
        const names = {};
        if (Array.isArray(accs)) for (const a of accs) names[String(a.login)] = a.display_name || String(a.login);
        const money = (n) => (n >= 0 ? '+$' : '-$') + Math.abs(Math.round(n)).toLocaleString();
        const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
        const render = (login) => {
          const sel = login == null ? rows : rows.filter((b) => String(b.account_login) === login);
          let sum = 0, win = 0;
          for (const b of sel) { const p = Number(b.pnl_usd) || 0; sum += p; if (p >= 0) win++; }
          const wr = sel.length ? Math.round((win / sel.length) * 100) : 0;
          const pnlEl = document.getElementById('tj-pnl');
          if (pnlEl) { pnlEl.textContent = money(sum); pnlEl.style.color = sum >= 0 ? '' : '#ff665d'; }
          set('tj-wr', wr + '%');
          set('tj-ct', String(sel.length));
        };
        // toggle รวม/ต่อพอร์ต — โชว์เมื่อมีมากกว่า 1 พอร์ตจริงในข้อมูล (label จาก accounts.display_name, fallback เลขบัญชี)
        const logins = [...new Set(rows.map((b) => (b.account_login == null ? '' : String(b.account_login))).filter(Boolean))].sort();
        const wrap = document.getElementById('tj-toggle');
        if (wrap && logins.length > 1) {
          const OFF = 'flex-1 rounded-md py-1 cursor-pointer bg-transparent text-gray-dark text-[11px] font-semibold border-0';
          const ON = 'flex-1 rounded-md py-1 cursor-pointer bg-primary text-white text-[11px] font-semibold border-0';
          const mk = (label, login) => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.textContent = label;
            btn.className = OFF;
            btn.addEventListener('click', () => {
              wrap.querySelectorAll('button').forEach((b) => { b.className = OFF; });
              btn.className = ON;
              render(login);
            });
            wrap.appendChild(btn);
            return btn;
          };
          mk('รวม', null).className = ON;
          logins.forEach((l) => mk(names[l] || l, l));
          wrap.classList.remove('hidden');
          wrap.classList.add('flex');
        }
        render(null);
      })
      .catch(() => {});
  }
  // Myfxbook — API คาย array ทุกพอร์ต live; การ์ด SSR (มี 2 ใบตอน build) reuse ตามลำดับ พอร์ตเกินจากนั้น clone เพิ่มเอง
  fetch('https://www.intensivetrader.com/api/myfxbook.json')
    .then((r) => r.json())
    .then((raw) => {
      const list = document.getElementById('mfb-list');
      const ssrCards = list ? Array.from(list.querySelectorAll('[data-mfb-id]')) : [];
      const template = ssrCards[0];
      if (!list || !template) return;
      // API รุ่นเก่าคาย object พอร์ตเดียว (ไม่มี id/name) — ถือเป็นพอร์ต 1 (การ์ด SSR ใบแรก)
      let accounts = raw;
      if (!Array.isArray(accounts)) {
        if (!accounts || accounts.gain == null) return;
        const lbl = template.querySelector('.mfb-label');
        accounts = [{ id: template.getAttribute('data-mfb-id'), name: lbl ? (lbl.textContent || '').split(' · ')[0] : '', ...accounts }];
      }
      if (accounts.length === 0) return;
      const slugify = (s) => (s || 'account').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
      accounts.forEach((acc, i) => {
        // หาการ์ดตาม id ก่อน — ไม่เจอ (พอร์ตใหม่ที่ fallback ตอน build) ใช้การ์ด SSR ตามลำดับ — เกินจำนวน SSR ค่อย clone
        let card = list.querySelector(`[data-mfb-id="${acc.id}"]`) || ssrCards[i];
        let isNew = false;
        if (!card) {
          card = template.cloneNode(true);
          list.appendChild(card);
          isNew = true;
        }
        card.setAttribute('data-mfb-id', String(acc.id));
        const set = (sel, v, pre, suf) => { const el = card.querySelector(sel); if (el && v != null) el.textContent = (pre || '') + v + (suf || ''); };
        set('.mfb-gain', acc.gain, '+', '%');
        set('.mfb-absgain', acc.absGain, '+', '%');
        set('.mfb-monthly', acc.monthly, '', '%');
        set('.mfb-dd', acc.drawdown, '', '%');
        set('.mfb-balance', acc.balance, '$', '');
        const gainEl = card.querySelector('.mfb-gain');
        if (gainEl && acc.gain != null) gainEl.classList.add('positive');
        const absGainEl = card.querySelector('.mfb-absgain');
        if (absGainEl && acc.absGain != null) absGainEl.classList.add('positive');
        const label = card.querySelector('.mfb-label');
        if (label && acc.name) label.textContent = `${acc.name} · พอร์ต ${i + 1}`;
        // มีตัวเลขจริงแล้ว — เอา note "พอร์ตใหม่ รอผูก" ออก
        if (acc.gain != null) { const note = card.querySelector('.mfb-new-note'); if (note) note.remove(); }
        // การ์ด SSR ที่มีลิงก์จริงอยู่แล้วคงเดิม — การ์ด clone/การ์ด fallback (href="#") คำนวณลิงก์เอง
        const link = card.querySelector('.mfb-link');
        if (link && (isNew || link.getAttribute('href') === '#')) link.href = `https://www.myfxbook.com/members/kwasati/${slugify(acc.name)}/${acc.id}`;
      });
    })
    .catch(() => {});
  document.querySelectorAll('.copy-code').forEach((btn) => {
    btn.addEventListener('click', () => {
      const code = btn.getAttribute('data-copy') || '';
      if (navigator.clipboard) navigator.clipboard.writeText(code);
      const prev = btn.textContent;
      btn.textContent = 'คัดลอกแล้ว!';
      setTimeout(() => { btn.textContent = prev; }, 1500);
    });
  });
</script>
</Layout>
