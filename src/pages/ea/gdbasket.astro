---
import Layout from '../../layouts/Layout.astro';

// content port จาก intensivetrader.com/src/pages/ea/gdbasket.astro (เดิม)
const MAIN = 'https://intensivetrader.com';
const DL_V200 = `${MAIN}/d/gdbasket`; // ปุ่มหลัก — redirect ชี้ไฟล์ v2.00 (publish/releases/v2.00/gdBasket_v2.00.ex5)
const DL_V137 = `${MAIN}/d/gdbasket-v137`;
const DL_V118 = `${MAIN}/d/gdbasket-v118`;
const XM_AFF = 'https://affs.click/jih0m';
const XM_CODE = 'KWASATI';

// Myfxbook — ดึงทุกพอร์ต live จาก /api/myfxbook.json ตอน build + fallback ต่อบัญชีกันพัง
// client script ท้ายไฟล์ refresh ค่าสดตอน runtime + clone การ์ดเพิ่มเองเมื่อ API คายพอร์ตใหม่ ไม่ต้องแก้ไฟล์นี้อีก
type MfbCard = {
  id: string; name: string; label: string; url: string | null; newNote: string | null;
  gain: string | null; absGain: string | null; monthly: string | null; drawdown: string | null; balance: string | null;
};
const mfbSlug = (s: string) => (s || 'account').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const mfbFallback: MfbCard[] = [
  { id: '12090186', name: 'gdbasket-xs', label: 'พอร์ต 1', url: 'https://www.myfxbook.com/members/kwasati/gdbasket-xs/12090186', newNote: null, gain: '53.40', absGain: '53.45', monthly: '53.40', drawdown: '18.16', balance: '460.36' },
  { id: '12105756', name: 'gdbasket lx', label: 'พอร์ต 2', url: 'https://www.myfxbook.com/members/kwasati/gdbasket-lx/12105756', newNote: 'พอร์ตใหม่ เริ่ม 2026-07', gain: null, absGain: null, monthly: null, drawdown: null, balance: null },
];
let mfbCards: MfbCard[] = mfbFallback;
try {
  const raw = await fetch('https://www.intensivetrader.com/api/myfxbook.json').then((r) => r.json());
  // API รุ่นเก่าคาย object พอร์ตเดียว (ไม่มี id/name) — แปลงเป็น array โดยถือเป็นพอร์ต 1; รุ่นใหม่คาย array ทุกพอร์ต live
  const accounts = Array.isArray(raw) ? raw : (raw && raw.gain != null ? [{ id: mfbFallback[0].id, name: mfbFallback[0].name, ...raw }] : []);
  if (accounts.length > 0) {
    const f = (n: unknown) => (n == null ? null : Number(n).toFixed(2));
    const toCard = (acc: any, base: MfbCard): MfbCard => ({
      ...base,
      id: String(acc.id),
      name: acc.name || base.name,
      url: `https://www.myfxbook.com/members/kwasati/${mfbSlug(acc.name || base.name)}/${acc.id}`,
      newNote: null,
      gain: f(acc.gain), absGain: f(acc.absGain), monthly: f(acc.monthly), drawdown: f(acc.drawdown), balance: f(acc.balance),
    });
    const used = new Set<string>();
    mfbCards = mfbFallback.map((fb) => {
      const acc = accounts.find((a: any) => String(a.id) === fb.id || (a.name || '').toLowerCase() === fb.name.toLowerCase());
      if (!acc) return fb; // fallback ต่อบัญชี — API ยังไม่คืนพอร์ตนี้
      used.add(String(acc.id));
      return toCard(acc, fb);
    });
    // พอร์ตใหม่ที่ยังไม่รู้จัก — ต่อท้ายเป็นการ์ดเพิ่ม
    for (const acc of accounts) {
      if (!used.has(String(acc.id))) mfbCards.push(toCard(acc, { id: '', name: '', label: `พอร์ต ${mfbCards.length + 1}`, url: null, newNote: null, gain: null, absGain: null, monthly: null, drawdown: null, balance: null }));
    }
  }
} catch (e) { /* ใช้ fallback */ }

const features = [
  { title: 'Buy Grid ถัวเฉลี่ย (DCA)', desc: 'เปิด Buy เป็นชุด ราคาลงวางเพิ่มเรื่อยๆ ถัวต้นทุนให้ต่ำลง รอราคาเด้งกลับปิดทั้งตะกร้า' },
  { title: 'ระยะกริดปรับตามตลาด (ATR)', desc: 'ระยะห่างระหว่างไม้ไม่ได้ fix — คำนวณจากความผันผวนจริง (ATR M15) ตลาดผันผวนมากกริดถ่างขึ้นอัตโนมัติ' },
  { title: 'ปิดทั้งตะกร้าจุดเดียว (Common TP)', desc: 'ทุกไม้ใช้เป้ากำไรราคาเดียวกัน broker เป็นคนปิดให้ — ไม่ต้องเฝ้าจอ' },
  { title: 'SL กันตายที่ broker', desc: 'วาง SL จริงร่วมทุกไม้เป็น backstop กันพอร์ตแตกหนักเมื่อ EA ดับ / ตลาดปิด / ราคากระโดด' },
  { title: 'โหมด SPORT+ (เครื่องยนต์ 2 บ้าน)', desc: 'สลับชุดค่าตามโซนราคาอัตโนมัติ (บ้าน high/low) + ระบบกันวางไม้ถี่เกิน (Spawn Guard) + trail อัตโนมัติผูกตามบ้านที่เปิดรอบ' },
  { title: 'รองรับ GOLD# Std + GOLDm# Micro', desc: 'เลือก Auto / Standard / Micro — ปรับ lot ให้พอดีบัญชี XM ทั้งบัญชีใหญ่และไมโคร' },
];

const howSteps = [
  'เปิดไม้แรกตามเวลา (ไม่ใช้ indicator จับสัญญาณ)',
  'ราคาลงถึงระยะกริด (คิดจาก ATR) → วาง Buy เพิ่มถัวเฉลี่ย',
  'ตั้งเป้ากำไรรวม (common TP) ราคาเดียวทุกไม้ — ราคาแตะ broker ปิดทั้งตะกร้า',
  'มี SL จริงที่ broker เป็นตัวกันตาย (กรณี EA ดับ / ตลาดปิด / ราคา gap)',
];

const releases = [
  { version: 'v2.00', date: '2026-07-08', latest: true, note: 'ยกเครื่องยนต์ใหม่ทั้งชุด — ตัวแจกโหมด SPORT+', url: DL_V200 },
  { version: 'v1.37', date: '2026-06-24', latest: false, note: 'ปรับวิธีบันทึกผลตอนพอร์ตแตก (ขาดทุนสุทธิจริง) + ใช้ SL ที่ broker เป็นตัวปิดหลัก', url: DL_V137 },
  { version: 'v1.18', date: '2026-06-13', latest: false, note: 'แก้บั๊กตรวจพอร์ตแตกผิดพลาด (false SO) ตอนเจอ bad tick / ข่าว / สเปรดกระชาก', url: DL_V118 },
];

// file-list rows (github metaphor -> สารบัญ EA)
const fileRows = [
  { icon: 'doc', name: 'README — ภาพรวม EA', note: 'Buy Grid GOLD M15 · DCA + ATR grid + common TP', meta: 'อ่าน', href: '#readme', color: 'text-gray' },
  { icon: 'gear', name: 'วิธีติดตั้ง', note: 'ลงใน MT5 · MQL5\\Experts\\ · ลากใส่กราฟ GOLD M15', meta: '6 ขั้น', href: '#install', color: 'text-secondary' },
  { icon: 'modes', name: 'โหมดการทำงาน', note: 'SPORT+ · เครื่องยนต์ 2 บ้าน high/low สลับชุดค่าตามโซนราคา', meta: '1', href: '#modes', color: 'text-primary' },
  { icon: 'star', name: 'จุดเด่น', note: '6 ข้อ · DCA / ATR / common TP / SL / SPORT+ / Std+Micro', meta: '6', href: '#features', color: 'text-primary' },
  { icon: 'clock', name: 'บันทึกเวอร์ชัน', note: 'v2.00 (2026-07-08) · v1.37 (2026-06-24) · v1.18 (2026-06-13)', meta: '3 rel', href: '#releases', color: 'text-gray' },
  { icon: 'dl', name: 'gdBasket_v2.00.ex5', note: 'ไฟล์ EA พร้อมใช้ · MT5 · โหลดฟรี', meta: 'ดาวน์โหลด', href: DL_V200, color: 'text-green', download: true },
  { icon: 'journal', name: 'Trading Journal', note: 'ประวัติการเทรดจริงรายวัน · กำไร/ขาดทุนต่อรอบ', meta: 'ดูประวัติ', href: `${MAIN}/journal`, color: 'text-primary', accent: true },
];

const installSteps = [
  'โหลดไฟล์ <strong>gdBasket_v2.00.ex5</strong> จากปุ่มด้านบน',
  'เปิด <strong>MetaTrader 5</strong> → เมนู <strong>File → Open Data Folder</strong>',
  'วางไฟล์ใน <code class="install-path">MQL5\\Experts\\</code>',
  '<strong>Restart MT5</strong> หรือกด <strong>Refresh</strong> ใน Navigator',
  'ลาก <strong>gdBasket</strong> ใส่กราฟ <strong>GOLD M15</strong> → ติ๊ก <strong>Allow Algo Trading</strong> → OK แล้วกดปุ่ม <strong>Algo Trading</strong> บนแถบเครื่องมือ MT5 ให้เป็น<strong class="text-green">สีเขียว</strong>',
  'ตั้งค่า <strong>Capital</strong> = เงินที่ยอมเสียได้ต่อรอบ — บัญชี <strong>Standard</strong> ตั้งขั้นต่ำ <strong>$1,000</strong> · บัญชี <strong>Micro</strong> ตั้งขั้นต่ำ <strong>$100</strong> (ต่ำกว่านี้ EA จะไม่เปิดออเดอร์) — ส่วนโหมด EA ตั้ง <strong>SPORT+</strong> มาให้แล้ว ไม่ต้องเลือก',
];
---

<Layout title="gdBasket — Buy Grid EA สำหรับ GOLD M15 | Room" description="gdBasket — MQL5 Buy Grid EA บน GOLD M15 ใช้จริงบนพอร์ตจริง. โหลดฟรี v2.00" ogImage="https://room.intensivetrader.com/gdbasket-og.png">
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">

  <!-- breadcrumb -->
  <div class="text-sm text-gray-dark mb-4">
    <a href="/" class="text-gray hover:text-primary transition-colors">Room</a><span class="mx-1">/</span>
    <a href="/?filter=ea" class="text-gray hover:text-primary transition-colors">EA</a><span class="mx-1">/</span>
    <span class="text-gray-light font-semibold">gdBasket</span>
  </div>

  <!-- (a) REPO HEADER ROW -->
  <div class="flex justify-between items-start gap-4 flex-wrap pb-4">
    <div class="flex items-center gap-3">
      <img src="/gdbasket-mark.png" class="w-8 h-8 rounded-lg bg-dark-border" alt="gdBasket" />
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-lg text-gray">IntensiveTrader</span>
        <span class="text-lg text-gray-dark">/</span>
        <span class="pixel text-primary text-[15px]">gdBasket</span>
        <span class="inline-flex items-center gap-1.5 bg-dark border border-green/40 text-green px-2.5 py-0.5 rounded-full text-xs font-semibold">LIVE จริง</span>
      </div>
    </div>
    <div class="flex items-center rounded-lg border border-dark-border overflow-hidden text-sm">
      <span class="px-3 py-1.5 text-gray">เวอร์ชัน</span>
      <span class="px-3 py-1.5 bg-dark border-l border-dark-border text-gray-light font-semibold">v2.00</span>
    </div>
  </div>

  <!-- (b) SUB-NAV TABS -->
  <div class="border-b border-dark-border flex gap-1 text-sm overflow-x-auto">
    <a href="#readme" class="px-3 py-2.5 border-b-2 border-primary text-gray-light font-semibold whitespace-nowrap">โค้ด/ไฟล์</a>
    <a href="#readme" class="px-3 py-2.5 border-b-2 border-transparent text-gray hover:text-gray-light whitespace-nowrap">วิธีทำงาน</a>
    <a href="#features" class="px-3 py-2.5 border-b-2 border-transparent text-gray hover:text-gray-light whitespace-nowrap">จุดเด่น</a>
    <a href="#releases" class="px-3 py-2.5 border-b-2 border-transparent text-gray hover:text-gray-light whitespace-nowrap flex items-center gap-1.5">Releases <span class="bg-dark-border text-gray-light text-[10px] px-1.5 rounded-full">3</span></a>
    <a href={`${MAIN}/journal`} class="px-3 py-2.5 border-b-2 border-transparent text-primary hover:text-primary-dark font-semibold whitespace-nowrap">Trading Journal</a>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-8 mt-5">

    <!-- LEFT -->
    <div>
      <!-- (c) TOOLBAR -->
      <div class="flex items-center gap-3 flex-wrap mb-3">
        <span class="flex items-center gap-2 bg-dark-card border border-dark-border rounded-lg px-3 py-1.5 text-sm text-gray-light">
          <svg class="w-4 h-4 text-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v10m0-10a2 2 0 100-4 2 2 0 000 4zm0 10a2 2 0 100 4 2 2 0 000-4zm8-6a2 2 0 100-4 2 2 0 000 4zm0 0v1a3 3 0 01-3 3H9"/></svg>
          <span class="font-semibold">v2.00</span>
        </span>
        <span class="text-sm text-gray flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5a1.99 1.99 0 011.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.99 1.99 0 013 12V7a4 4 0 014-4z"/></svg>
          <span class="text-gray-light font-semibold">3</span> เวอร์ชัน
        </span>
        <div class="flex-1 min-w-[120px]"></div>
        <a href={DL_V200} download class="flex items-center gap-2 bg-primary hover:bg-primary-dark text-white px-4 py-1.5 rounded-lg font-bold text-sm transition-colors pixel-shadow">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          ดาวน์โหลด
        </a>
        <p class="text-[11px] text-gray-dark text-right w-full leading-relaxed">ไฟล์เวอร์ชัน <strong class="text-secondary font-semibold">v2.00</strong> — ใช้ได้เฉพาะบัญชี <strong class="text-secondary font-semibold">XM</strong> (โบรก XM Global + GOLD + M15 เท่านั้น — ล็อกในตัว EA)</p>
      </div>

      <!-- (d) LATEST-COMMIT BAR -->
      <div class="flex items-center gap-3 bg-dark-card border border-dark-border rounded-t-xl px-4 py-2.5 text-sm flex-wrap">
        <img src={`${MAIN}/profile.jpg`} class="w-5 h-5 rounded-full bg-dark-border" alt="" />
        <span class="text-gray-light font-semibold">IntensiveTrader</span>
        <span class="text-gray truncate flex-1 min-w-[120px]">v2.00 — ยกเครื่องยนต์ใหม่ทั้งชุด: โหมด SPORT+</span>
        <span class="text-gray-dark whitespace-nowrap">อัปเดต 2026-07-09</span>
      </div>

      <!-- (e) FILE LIST -->
      <div class="border border-t-0 border-dark-border rounded-b-xl overflow-hidden text-sm mb-8">
        {fileRows.map((row, i) => (
          <a
            href={row.href}
            {...(row.download ? { download: true } : {})}
            class={`flex items-center gap-3 px-4 py-2.5 hover:bg-dark-card transition-colors cursor-pointer ${i < fileRows.length - 1 ? 'border-b border-dark-border' : ''}`}
          >
            <span class={`shrink-0 ${row.color}`}>
              {row.icon === 'doc' && <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M4 4h16v2H4zm0 5h16v2H4zm0 5h11v2H4z"/></svg>}
              {row.icon === 'gear' && <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>}
              {row.icon === 'modes' && <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>}
              {row.icon === 'star' && <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>}
              {row.icon === 'clock' && <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>}
              {row.icon === 'dl' && <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>}
              {row.icon === 'journal' && <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>}
            </span>
            <span class="text-gray-light font-medium w-[190px] max-md:w-[130px] shrink-0">{row.name}</span>
            <span class="text-gray truncate flex-1 max-md:hidden">{row.note}</span>
            <span class={`whitespace-nowrap text-xs ${(row.download || row.accent) ? 'text-primary font-semibold' : 'text-gray-dark'}`}>{row.meta}{(row.download || row.accent) ? ' →' : ''}</span>
          </a>
        ))}
      </div>

      <!-- (aff) XM AFFILIATE CARD -->
      <div class="rounded-xl border border-secondary/40 p-5 mb-8" style="background:linear-gradient(160deg,rgba(245,158,11,.07),rgba(26,26,26,.5))">
        <div class="text-xs text-secondary font-bold mb-1">โบรกที่ผมเทรดเอง</div>
        <h3 class="text-lg font-bold text-gray-light mb-2">gdBasket ทำมาเพื่อ XM โดยเฉพาะ</h3>
        <p class="text-sm text-gray mb-4">EA ตัวนี้ล็อกให้รันเฉพาะ GOLD บน XM — ใครจะเอาไปใช้ต้องมีบัญชี XM ก่อน ผมเทรดโบรกนี้เอง เปิดผ่านลิงก์ผมได้โบนัสเติมเงินด้วย</p>
        <div class="flex gap-2 flex-wrap mb-4 text-xs font-semibold">
          <span class="bg-dark border border-dark-border rounded-lg px-3 py-1.5 text-gray-light">Leverage <span class="text-secondary">1:1000</span></span>
          <span class="bg-dark border border-dark-border rounded-lg px-3 py-1.5 text-gray-light">โบนัสเติมเงิน <span class="text-secondary">100%</span></span>
          <span class="bg-dark border border-dark-border rounded-lg px-3 py-1.5 text-gray-light">เปิดบัญชี <span class="text-secondary">ฟรี</span></span>
        </div>
        <div class="flex items-center gap-2 flex-wrap bg-dark border border-dashed border-secondary rounded-lg px-3 py-2.5 mb-3 text-sm">
          <span class="text-gray-dark text-xs">รหัสผู้แนะนำ:</span>
          <span class="font-mono font-bold text-white bg-primary px-2.5 py-0.5 rounded">{XM_CODE}</span>
          <button type="button" data-copy={XM_CODE} class="copy-code text-xs font-semibold text-gray-light bg-dark-card border border-dark-border rounded px-2.5 py-1 cursor-pointer">คัดลอก</button>
        </div>
