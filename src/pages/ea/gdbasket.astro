import Layout from '../../layouts/Layout.astro';

// content port จาก intensivetrader.com/src/pages/ea/gdbasket.astro (เดิม)
const MAIN = 'https://intensivetrader.com';
const DL_LATEST = `${MAIN}/d/gdbasket`; // ปุ่มหลัก — redirect ชี้ไฟล์รุ่นล่าสุด v2.02 (publish/releases/v2.02/gdBasket_v2.02.ex5)
const DL_V201 = `${MAIN}/d/gdbasket-v201`;
const DL_V200 = `${MAIN}/d/gdbasket-v200`;
const DL_V137 = `${MAIN}/d/gdbasket-v137`;
const DL_V118 = `${MAIN}/d/gdbasket-v118`;
const XM_AFF = 'https://affs.click/jih0m';
const XM_CODE = 'KWASATI';
const VPS_AFF = 'https://bit.ly/MTCloudVPS';

// Myfxbook — ดึงทุกพอร์ต live จาก /api/myfxbook.json ตอน build + fallback ต่อบัญชีกันพัง
// client script ท้ายไฟล์ refresh ค่าสดตอน runtime + clone การ์ดเพิ่มเองเมื่อ API คายพอร์ตใหม่ ไม่ต้องแก้ไฟล์นี้อีก
type MfbCard = {
  id: string; name: string; label: string; url: string | null; newNote: string | null;
  gain: string | null; absGain: string | null; monthly: string | null; drawdown: string | null; balance: string | null;
};
const mfbSlug = (s: string) => (s || 'account').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const mfbFallback: MfbCard[] = [
  { id: '12090186', name: 'gdbasket-xs', label: 'พอร์ต 1', url: 'https://www.myfxbook.com/members/kwasati/gdbasket-xs/12090186', newNote: null, gain: '53.40', absGain: '53.45', monthly: '53.40', drawdown: '18.16', balance: '460.36' },
  { id: '12105756', name: 'gdbasket lx', label: 'พอร์ต 2', url: 'https://www.myfxbook.com/members/kwasati/gdbasket-lx/12105756', newNote: 'พอร์ตใหม่ เริ่ม 2026-07', gain: null, absGain: null, monthly: null, drawdown: null, balance: null },
];
let mfbCards: MfbCard[] = mfbFallback;
try {
  const raw = await fetch('https://www.intensivetrader.com/api/myfxbook.json').then((r) => r.json());
  // API รุ่นเก่าคาย object พอร์ตเดียว (ไม่มี id/name) — แปลงเป็น array โดยถือเป็นพอร์ต 1; รุ่นใหม่คาย array ทุกพอร์ต live
  const accounts = Array.isArray(raw) ? raw : (raw && raw.gain != null ? [{ id: mfbFallback[0].id, name: mfbFallback[0].name, ...raw }] : []);
  if (accounts.length > 0) {
    const f = (n: unknown) => (n == null ? null : Number(n).toFixed(2));
    const toCard = (acc: any, base: MfbCard): MfbCard => ({
      ...base,
      id: String(acc.id),
      name: acc.name || base.name,
      url: `https://www.myfxbook.com/members/kwasati/${mfbSlug(acc.name || base.name)}/${acc.id}`,
      newNote: null,
      gain: f(acc.gain), absGain: f(acc.absGain), monthly: f(acc.monthly), drawdown: f(acc.drawdown), balance: f(acc.balance),
    });
    const used = new Set<string>();
    mfbCards = mfbFallback.map((fb) => {
      const acc = accounts.find((a: any) => String(a.id) === fb.id || (a.name || '').toLowerCase() === fb.name.toLowerCase());
      if (!acc) return fb; // fallback ต่อบัญชี — API ยังไม่คืนพอร์ตนี้
      used.add(String(acc.id));
      return toCard(acc, fb);
    });
    // พอร์ตใหม่ที่ยังไม่รู้จัก — ต่อท้ายเป็นการ์ดเพิ่ม
    for (const acc of accounts) {
      if (!used.has(String(acc.id))) mfbCards.push(toCard(acc, { id: '', name: '', label: `พอร์ต ${mfbCards.length + 1}`, url: null, newNote: null, gain: null, absGain: null, monthly: null, drawdown: null, balance: null }));
    }
  }
} catch (e) { /* ใช้ fallback */ }

const features = [
  { title: 'Adaptive Buy Grid', desc: 'ราคาลงยิ่งซื้อเพิ่มถัวเฉลี่ย ระยะซื้อปรับตามความเหวี่ยงตลาดเอง ไม่ไล่ซื้อรัวจนพอร์ตบาน' },
  { title: 'Common-TP', desc: 'เป้ากำไรร่วมวางจริงที่โบรก ถึงเป้าปิดทั้งชุดให้เองแม้คอมดับ/ปิดโปรแกรม' },
  { title: 'PPTS', desc: 'ราคาวิ่งเข้าทางไม่รีบปิด ไล่ล็อกกำไรตามขึ้นไป ให้กำไรวิ่งต่อโดยไม่คืนของ' },
  { title: 'Broker-side Stop', desc: 'จุดตัดขาดทุนจริงที่โบรกเป็นกันชนสุดท้าย กันพอร์ตเสียหนักตอนตลาดกระโดด' },
  { title: 'Engine Profile', desc: '3 สไตล์การขับ เลือกตามความกล้าเสี่ยง แต่ละตัวอ่านจังหวะตลาดแล้วปรับวิธีเล่นเอง' },
  { title: 'Std + Micro Ready', desc: 'รองรับทั้งบัญชีใหญ่และไมโคร ปรับขนาดไม้ให้พอดีบัญชีอัตโนมัติ' },
];

const howSteps = [
  '<strong class="text-gray-light">Hour Entry :</strong> เปิดไม้แรกตามจังหวะเวลา — ไม่ต้องรอสัญญาณอะไรให้ปวดหัว ใช้กลไกเปิดออเดอร์ทุกต้นชั่วโมงในจังหวะที่ตลาดเป็นใจ',
  'ราคาลงถึงระยะที่มันคำนวณไว้ → ทยอยซื้อเพิ่มถัวเฉลี่ยแบบอัจฉริยะ (<strong class="text-gray-light">Adaptive Grid</strong>) ระยะห่างปรับตามความเหวี่ยงตลาดเอง',
  'ตั้งเป้ากำไรร่วมไว้จุดเดียว (<strong class="text-gray-light">Common-TP</strong>) → ราคาแตะ โบรกปิดทั้งชุดให้ รับกำไรพร้อมกันทุกไม้ ไม่หวังพึ่งการส่งคำสั่งจาก EA ที่ปิดช้าไม่ทันกิน',
  'มี <strong class="text-gray-light">Broker-side Stop</strong> วางจริงที่โบรก เผื่อวันตลาดกระโดดแรงหรือ EA ดับ — พอร์ตไม่เสียหายเกินที่ตั้งไว้',
];

const releases = [
  { version: 'v2.02', dateLabel: '13 ก.ค. 2026', latest: true, url: DL_LATEST },
  { version: 'v2.01', dateLabel: '10 ก.ค. 2026', latest: false, url: DL_V201 },
  { version: 'v2.00', dateLabel: '8 ก.ค. 2026', latest: false, url: DL_V200 },
  { version: 'v1.37', dateLabel: '24 มิ.ย. 2026', latest: false, url: DL_V137 },
  { version: 'v1.18', dateLabel: '13 มิ.ย. 2026', latest: false, url: DL_V118 },
];

// file-list rows (github metaphor -> สารบัญ EA)
const fileRows = [
  { icon: 'doc', name: 'ภาพรวม gdBasket', note: 'Adaptive Buy Grid Behavior EA · ทยอยซื้อเป็นชุด ปิดรับกำไรทั้งชุด', meta: 'อ่าน', href: '#readme', color: 'text-gray' },
  { icon: 'gear', name: 'วิธีติดตั้ง', note: 'ลงใน MT5 · ลากใส่กราฟ GOLD M15 · 6 ขั้นจบ', meta: '6 ขั้น', href: '#install', color: 'text-secondary' },
  { icon: 'modes', name: 'Engine Profile', note: 'STRADA+ / SPORT+ / CORSA — เลือกตามความกล้าเสี่ยง', meta: '3', href: '#modes', color: 'text-primary' },
  { icon: 'star', name: 'จุดเด่น', note: 'Adaptive Grid / Common-TP / PPTS / Broker-side Stop', meta: '6', href: '#features', color: 'text-primary' },
  { icon: 'clock', name: 'Releases', note: 'v2.02 · v2.01 · v2.00 · v1.37', meta: '5 rel', href: '/gdbasket-changelog.html', color: 'text-gray' },
  { icon: 'dl', name: 'gdBasket v2.02', note: 'พร้อมใช้ · โหลดฟรี', meta: 'ดาวน์โหลด', href: DL_LATEST, color: 'text-green', download: true },
  { icon: 'journal', name: 'Trading Journal', note: 'ผลเทรดจริงรายวัน · กำไร/ขาดทุนต่อรอบ', meta: 'ดูประวัติ', href: `${MAIN}/journal`, color: 'text-primary', accent: true },
];

const installSteps = [
  'ดาวน์โหลดไฟล์ <strong>gdBasket v2.02</strong> จากปุ่มด้านบน',
  'เปิด <strong>MetaTrader 5</strong> → <strong>File → Open Data Folder</strong>',
  'วางไฟล์ในโฟลเดอร์ <code class="install-path">MQL5 → Experts</code>',
  'ปิดเปิด MT5 ใหม่ หรือกด <strong>Refresh</strong> ใน Navigator',
  'ลาก <strong>gdBasket</strong> ใส่กราฟ <strong>GOLD M15</strong> → ติ๊กอนุญาตเทรดอัตโนมัติ → กดปุ่ม <strong>Algo Trading</strong> ให้ขึ้น<strong class="text-green">สีเขียว</strong>',
  'ตั้ง <strong>Capital</strong> = เงินที่ยอมเสียได้ต่อรอบ — Standard ขั้นต่ำ <strong>$1,000</strong> · Micro ขั้นต่ำ <strong>$100</strong> (ต่ำกว่านี้ EA จะไม่เปิดออเดอร์) ส่วน Engine Profile ตั้ง <strong>SPORT+</strong> มาให้แล้ว ไม่ต้องเลือก — สายนิ่งอยากได้ตัวกรองความร้อนตลาด ค่อยสลับเป็น <strong>STRADA+</strong>',
];

// Engine Profile — 3 เครื่องยนต์ (markup-only render data สำหรับ engine-tabs ใหม่ ไม่กระทบ const/array เดิมด้านบน)
const engines = [
  {
    key: 'strada', name: 'STRADA+', subtitle: 'grand tourer',
    badge: 'พร้อมใช้ · ใหม่ใน v2.01 · เน้นนิ่ง · ปลอดภัย',
    copy: [
      'ขับทางไกลแบบนิ่งๆ เลือกจังหวะเข้าที่มั่นใจ เก็บกำไรเรื่อยๆ ไม่หวือหวา เหมาะกับคนอยากนอนหลับสบาย',
      'มี<strong>ตัวกรองความร้อนตลาด</strong>ติดมาในตัว — วันไหนตลาดผันผวนแรงกว่าค่าเฉลี่ย 5 วันของตัวเอง มันงดเปิดกองใหม่ให้อัตโนมัติ รอตลาดเย็นลงค่อยเริ่มกองถัดไป เลือก STRADA+ ก็ได้เลย ไม่ต้องตั้งอะไรเพิ่ม',
    ],
    profit: '+90,184', wins: '10', stops: '3',
  },
  {
    key: 'sport', name: 'SPORT+', subtitle: 'สปอร์ตสมดุล',
    badge: 'พร้อมใช้ · แนะนำ · ตั้งมาให้แล้ว',
    copy: [
      'สมดุลระหว่างบุกกับเซฟ รู้จักดูว่าทองอยู่โซนแพงหรือถูกแล้วปรับสไตล์เล่นให้เหมาะกับจังหวะนั้น มีระบบเบรกกันเร่งเกินตอนตลาดดิ่งแรง — เป็นตัวที่ตั้งมาให้ในไฟล์แจก ลงแล้วใช้ได้เลย',
    ],
    profit: '+199,673', wins: '28', stops: '20',
  },
  {
    key: 'corsa', name: 'CORSA', subtitle: 'track-bred',
    badge: 'เร็วๆ นี้ · คันเร่งจัด · เสี่ยงสูง',
    copy: [
      'สายซิ่งเต็มคันเร่ง ไม้หนักกว่า กำไรต่อรอบแรงกว่า แลกกับความเสี่ยงที่สูงขึ้น เหมาะกับคนรับความเหวี่ยงได้และเข้าใจความเสี่ยงดี',
    ],
    profit: '—', wins: '—', stops: '—',
  },
];
