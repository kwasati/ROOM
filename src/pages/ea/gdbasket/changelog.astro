// ย้ายมาจาก public/gdbasket-changelog.html (§3.1) — หน้าตาเท่าเดิม 100%, แค่เปลี่ยนที่อยู่ + เนื้อรุ่นล่าสุด
---
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="gdBasket Releases — ประวัติทุกเวอร์ชัน อัปเดตอะไรบ้างในแต่ละรุ่น">
<link rel="icon" type="image/png" href="/favicon.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+Thai:wght@400;500;600;700&family=Press+Start+2P&display=swap" rel="stylesheet">
<title>gdBasket — Releases | Room</title>
<style>
  :root{
    --primary:#DC2626; --primary-dark:#B91C1C; --primary-light:#EF4444;
    --secondary:#F59E0B;
    --dark:#0F0F0F; --card:#1A1A1A; --border:#2A2A2A;
    --gray-light:#E5E7EB; --gray:#9CA3AF; --gray-dark:#6B7280;
    --green:#22C55E;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{background:var(--dark);color:var(--gray-light);
    font-family:'Noto Sans Thai','Inter',sans-serif;font-size:15px;line-height:1.6;
    -webkit-font-smoothing:antialiased}
  .pixel{font-family:'Press Start 2P',monospace}
  a{color:inherit;text-decoration:none}
  .wrap{max-width:960px;margin:0 auto;padding:0 16px}

  /* header */
  header{border-bottom:1px solid var(--border);padding:28px 0 20px}
  .crumb{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  .crumb .pixel{color:var(--primary);font-size:14px}
  .crumb .sep{color:var(--gray-dark);font-size:18px}
  .crumb .page{font-size:18px;font-weight:700;color:var(--gray-light)}
  header .sub{color:var(--gray);font-size:14px;margin-top:8px}
  .back{display:inline-block;margin-top:12px;font-size:13px;color:var(--gray);
    border:1px solid var(--border);border-radius:8px;padding:6px 14px;transition:.15s}
  .back:hover{color:var(--gray-light);border-color:var(--primary)}

  /* release list — github style: meta rail ซ้าย + การ์ดขวา */
  .releases{padding:32px 0 60px}
  .release{display:grid;grid-template-columns:190px 1fr;gap:20px;padding-bottom:36px}
  .meta{text-align:right;padding-top:4px}
  .meta .ver{font-size:12px;color:var(--gray-light);display:inline-flex;align-items:center;gap:8px}
  .meta .ver svg{width:15px;height:15px;color:var(--gray-dark);flex-shrink:0}
  .meta .date{font-size:12px;color:var(--gray-dark);margin-top:8px}
  .body{border-left:2px solid var(--border);padding-left:20px;position:relative;min-width:0}
  .body::before{content:"";position:absolute;left:-6px;top:10px;width:10px;height:10px;
    border-radius:50%;background:var(--border)}
  .release.latest .body::before{background:var(--green)}
  .card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:22px}
  .release.latest .card{border-color:rgba(34,197,94,.45)}
  .card .head{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:6px}
  .card h2{font-size:19px;font-weight:800;color:var(--gray-light)}
  .badge{font-size:11px;font-weight:700;padding:2px 10px;border-radius:999px}
  .badge.latest{background:rgba(34,197,94,.12);color:var(--green);border:1px solid rgba(34,197,94,.4)}
  .card .vdate{font-size:12.5px;color:var(--gray-dark);margin-bottom:14px}
  .card .lead{font-size:14px;color:var(--gray);margin-bottom:16px}
  .card ul{list-style:none;display:flex;flex-direction:column;gap:11px;margin-bottom:20px}
  .card li{display:flex;gap:10px;font-size:14px;color:var(--gray);line-height:1.6}
  .card li .plus{color:var(--green);font-weight:800;flex-shrink:0}
  .card li strong{color:var(--gray-light)}
  .dl{display:inline-flex;align-items:center;gap:8px;background:var(--primary);color:#fff;
    font-weight:700;font-size:14px;padding:9px 18px;border-radius:10px;transition:.15s}
  .dl:hover{background:var(--primary-dark)}
  .dl svg{width:16px;height:16px}
  .dl.ghost{background:transparent;border:1px solid var(--border);color:var(--gray-light)}
  .dl.ghost:hover{border-color:var(--primary);color:#fff}

  footer{border-top:1px solid var(--border);padding:24px 0 44px;text-align:center;
    font-size:12px;color:var(--gray-dark);line-height:1.8}
  footer a{color:var(--secondary);font-weight:600}
  footer a:hover{text-decoration:underline}

  @media(max-width:720px){
    .release{grid-template-columns:1fr;gap:10px}
    .meta{text-align:left;display:flex;align-items:center;gap:14px;padding-top:0}
    .meta .date{margin-top:0}
    .body{border-left:none;padding-left:0}
    .body::before{display:none}
    .card{padding:18px 16px}
  }
</style>
</head>
