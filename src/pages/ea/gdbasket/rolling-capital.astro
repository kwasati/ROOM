<script>
  import { replay, monthlySeries, bootstrap, cyclesFromJson } from '../../../lib/rolling-sim.mjs';
  import { historicalChartGeometry, fanChartGeometry, buildFanSamples } from '../../../lib/rolling-chart.mjs';
  import cyclesJson from '../../../data/gdbasket-rolling-cycles.json';

  const cycles = cyclesFromJson(cyclesJson);
  const BOOTSTRAP_PATHS = 1000;
  const BOOTSTRAP_SEED = 20260723;
  const THAI_MONTHS = ['ม.ค.', 'ก.พ.', 'มี.ค.', 'เม.ย.', 'พ.ค.', 'มิ.ย.', 'ก.ค.', 'ส.ค.', 'ก.ย.', 'ต.ค.', 'พ.ย.', 'ธ.ค.'];
  const HORIZON_LABELS = { 6: '6 เดือน', 12: '1 ปี', 24: '2 ปี', 36: '3 ปี' };
  function fmtSpan(years) {
    const m = Math.round(years * 12);
    const y = Math.floor(m / 12), mo = m % 12;
    if (y === 0) return `${mo} เดือน`;
    if (mo === 0) return `${y} ปี`;
    return `${y} ปี ${mo} เดือน`;
  }
  const [PERIOD_START] = cyclesJson.meta.period.split(' to ');
  const START_MIN = PERIOD_START.slice(0, 7);
  const MIN_MONTHS_FOR_RANGE = 3; // ต้องตรงกับ MIN_MONTHS_FOR_RANGE ในฝั่ง frontmatter (rolling-capital.astro)
  const MAXLOT_GUARD_CAP = 1250000; // ต้องตรงกับ MAXLOT_GUARD_CAP ในฝั่ง frontmatter (rolling-capital.astro)

  const state = { capital: 10000, buffer: 2, step: 3, withdrawPct: 50, horizon: 12, startMonth: START_MIN };

  function thaiDate(iso) {
    if (!iso) return '-';
    const d = new Date(iso);
    return `${d.getDate()} ${THAI_MONTHS[d.getMonth()]} ${d.getFullYear()}`;
  }
  function thaiMonthYear(iso) {
    const d = new Date(iso);
    return `${THAI_MONTHS[d.getMonth()]} ${d.getFullYear()}`;
  }
  function money(n) {
    return '$' + Math.round(n).toLocaleString('en-US');
  }
  function pct(n) {
    return n.toFixed(2) + '%';
  }
  function coverageLabel(n) {
    return n.toFixed(2) + ' เท่า';
  }
  function coverageRiskClass(n) {
    return n < 1 ? 'danger' : n < 2 ? 'warn' : '';
  }
  function coverageTableClass(n) {
    return n < 1 ? 'negative' : n < 2 ? 'warn' : '';
  }
  function coverageRiskLabel(n) {
    return n < 1 ? 'กินทุนแล้ว' : n < 2 ? 'ยังไม่กินทุน แต่เบาะเหลือน้อย' : 'เบาะยังหนา';
  }
  function esc(s) {
    return String(s).replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]));
  }
  function filterCyclesFrom(startMonth) {
    if (!startMonth || startMonth <= START_MIN) return cycles;
    const startISO = `${startMonth}-01`;
    return cycles.filter((c) => String(c.t) >= startISO);
  }

  function computeView() {
    const rangeCycles = filterCyclesFrom(state.startMonth);
    const monthCount = new Set(rangeCycles.map((c) => String(c.t).slice(0, 7))).size;
    if (rangeCycles.length === 0 || monthCount < MIN_MONTHS_FOR_RANGE) {
      return { tooShort: true, rangeCount: rangeCycles.length, monthCount };
    }

    const withdrawRate = state.withdrawPct / 100;
    const params = { backing: state.buffer, step: state.step, withdrawRate, sourceCap: state.capital };
    const summary = replay(rangeCycles, params);
    const { months } = monthlySeries(rangeCycles, params);
    const hist = historicalChartGeometry(months);

    const bsState = {
      cap: summary.finalCap,
      surplus: summary.finalSurplus,
      withdrawn: summary.withdrawnCash,
      backing: state.buffer,
      step: state.step,
      withdrawRate,
      initialActive: state.buffer * state.capital,
    };
    const samples = buildFanSamples(bootstrap, rangeCycles, bsState, state.horizon, summary.totalWealth, BOOTSTRAP_PATHS, BOOTSTRAP_SEED);
    const fan = fanChartGeometry(samples);
    const lastSample = samples[samples.length - 1];

    const policyRows = [0, 0.5, 0.6, 0.7, 1].map((w) => replay(rangeCycles, { backing: state.buffer, step: state.step, withdrawRate: w, sourceCap: state.capital }));
    const backingRows = [1, 2, 3].map((b) => replay(rangeCycles, { backing: b, step: state.step, withdrawRate, sourceCap: state.capital }));

    const byYear = new Map();
    for (const e of summary.events) {
      const y = String(e.cycleTime).slice(0, 4);
      byYear.set(y, (byYear.get(y) || 0) + e.withdrawal);
    }
    const annualRows = Array.from(byYear.entries()).sort((a, b) => a[0].localeCompare(b[0]));

    const rangeStart = rangeCycles[0].t;
    const rangeEnd = rangeCycles[rangeCycles.length - 1].t;
    const rangeSpanYears = (new Date(rangeEnd) - new Date(rangeStart)) / (1000 * 60 * 60 * 24 * 365.25);
    const rangeSpanLabel = fmtSpan(rangeSpanYears);
    const rangePeriodLabel = `${thaiMonthYear(rangeStart)} - ${thaiMonthYear(rangeEnd)}`;

    return {
      tooShort: false,
      summary, hist, fan, lastSample, policyRows, backingRows, annualRows,
      rangeCount: rangeCycles.length, rangeSpanLabel, rangePeriodLabel,
    };
  }

  function render(view) {
    const guardEl = document.getElementById('range-guard-msg');

    // total funds + capital note (always independent of tooShort — capital field is separate from range)
    const totalFundsEl = document.getElementById('total-funds-value');
    if (totalFundsEl) totalFundsEl.textContent = money(state.capital * state.buffer);
    const capitalNoteEl = document.getElementById('capital-note');
    if (capitalNoteEl) capitalNoteEl.style.display = state.capital < 10000 ? 'block' : 'none';

    if (view.tooShort) {
      if (guardEl) guardEl.style.display = 'block';
      // เก็บตัวเลขก่อนหน้าไว้บนจอ ไม่เคลียร์ทิ้ง — กันจอว่าง/error, แค่บอกว่าเลขที่เห็นเป็นของช่วงก่อนหน้า
      return;
    }
    if (guardEl) guardEl.style.display = 'none';

    const { summary, hist, fan, lastSample, policyRows, backingRows, annualRows, rangeCount, rangeSpanLabel, rangePeriodLabel } = view;

    // period heading
    const histPeriodEl = document.getElementById('hist-period');
    if (histPeriodEl) histPeriodEl.textContent = `ผลจริง ${rangePeriodLabel} (${rangeCount.toLocaleString()} รอบ, ${rangeSpanLabel})`;

    // subline
    const sublineEl = document.getElementById('hist-subline');
    if (sublineEl) sublineEl.textContent = `ตั้ง Capital ${money(state.capital)} · ทุนค้ำ ${state.buffer}x · เกณฑ์ขึ้นชั้น ${state.step}x · ถอน ${state.withdrawPct}% ต่อชั้น — เล่นซ้ำผลจริงทุกรอบที่ gdBasket VELOCE ปิดจริง`;

    // KPI grid
    const coverageClass = coverageRiskClass(summary.minActiveCapCoverage);
    const statusText = summary.bust ? `แตกเมื่อ ${thaiDate(summary.bustTime)}` : `รอดตลอด ${rangeSpanLabel}`;
    const kpiEl = document.getElementById('kpi-grid');
    if (kpiEl) {
      kpiEl.innerHTML = `
        <div><dt>เงินถอนสะสม (ถอนออกมาใช้แล้ว)</dt><dd class="positive">${money(summary.withdrawnCash)}</dd></div>
        <div><dt>เงินในพอร์ตเหลือ</dt><dd class="positive">${money(summary.finalActiveFunds)}</dd></div>
        <div><dt>มูลค่ารวมสุทธิ (2 ก้อนรวมกัน)</dt><dd class="positive">${money(summary.totalWealth)}</dd></div>
        <div><dt>เฉียดตายแค่ไหน (เบาะเหลือต่ำสุด)</dt><dd class="${coverageClass}">${coverageLabel(summary.minActiveCapCoverage)}</dd></div>
        <div><dt>พอร์ตแดงลึกสุด%</dt><dd class="danger">${pct(summary.maxActiveFundsDdPct)}</dd></div>
        <div><dt>ขึ้นชั้น</dt><dd class="neutral">${summary.steps} ครั้ง</dd></div>
        <div><dt>คืนทุนตั้งต้นเมื่อ</dt><dd class="neutral">${summary.paybackDate ? thaiDate(summary.paybackDate) : 'ยังไม่คืน'}</dd></div>
        <div><dt>สถานะ</dt><dd class="${summary.bust ? 'danger' : 'positive'}">${statusText}</dd></div>
      `;
    }

    // coverage note (ณ ช่วงหนักสุด...)
    const coverageNoteValueEl = document.getElementById('coverage-note-value');
    const coverageNoteStatusEl = document.getElementById('coverage-note-status');
    if (coverageNoteValueEl) coverageNoteValueEl.textContent = coverageLabel(summary.minActiveCapCoverage);
    if (coverageNoteStatusEl) coverageNoteStatusEl.textContent = coverageRiskLabel(summary.minActiveCapCoverage);

    // max-lot guard — only surfaces when this scenario's peak cap blows past the
    // broker's per-order size ceiling (see MAXLOT_GUARD_CAP comment above)
    const maxlotGuardEl = document.getElementById('maxlot-guard');
    if (maxlotGuardEl) maxlotGuardEl.style.display = summary.peakCap > MAXLOT_GUARD_CAP ? '' : 'none';

    // historical chart
    const activeArea = document.getElementById('active-area');
    const withdrawnArea = document.getElementById('withdrawn-area');
    const totalLine = document.getElementById('total-line');
    const markersG = document.getElementById('markers');
    if (activeArea) activeArea.setAttribute('points', hist.activeAreaPoints);
    if (withdrawnArea) withdrawnArea.setAttribute('points', hist.withdrawnAreaPoints);
    if (totalLine) totalLine.setAttribute('points', hist.totalLinePoints);
    if (markersG) markersG.innerHTML = hist.markers.map((mk) => `<circle cx="${mk.x.toFixed(1)}" cy="${mk.y.toFixed(1)}" r="3.5" fill="#EF4444"></circle>`).join('');
    const stepsCountEl = document.getElementById('hist-steps-count');
    if (stepsCountEl) stepsCountEl.textContent = String(summary.steps);

    // policy comparison table
    const policyBody = document.getElementById('policy-tbody');
    if (policyBody) {
      policyBody.innerHTML = policyRows
        .map((r) => {
          const wPct = Math.round(r.withdrawRate * 100);
          const isSelected = wPct === state.withdrawPct;
          const label = r.withdrawRate === 0 ? '0% (ทบหมด)' : r.withdrawRate === 1 ? '100% (ถอนหมด)' : `${wPct}%`;
          const paybackCell = r.bust ? `แตก ${thaiDate(r.bustTime)}` : (r.paybackDate ? thaiDate(r.paybackDate) : '-');
          return `<tr class="${isSelected ? 'highlight' : ''}">
            <td>${label}${isSelected ? ' ← เลือกอยู่' : ''}</td>
            <td class="positive">${money(r.totalWealth)}</td>
            <td class="positive">${money(r.withdrawnCash)}</td>
            <td>${pct(r.maxActiveFundsDdPct)}</td>
            <td>${r.steps}</td>
            <td>${esc(paybackCell)}</td>
          </tr>`;
        })
        .join('');
    }

    // annual withdrawals
    const annualSection = document.getElementById('annual-section');
    const annualBody = document.getElementById('annual-tbody');
    if (annualSection) annualSection.style.display = state.withdrawPct > 0 ? '' : 'none';
    if (annualBody) {
      if (annualRows.length === 0) {
        annualBody.innerHTML = `<tr><td colspan="2">ยังไม่มีการถอนที่ setting นี้</td></tr>`;
      } else {
        const total = annualRows.reduce((a, [, amt]) => a + amt, 0);
        annualBody.innerHTML =
          annualRows.map(([y, amt]) => `<tr><td>${y}</td><td class="positive">${money(amt)}</td></tr>`).join('') +
          `<tr class="total"><td>รวม</td><td class="positive">${money(total)}</td></tr>`;
      }
    }

    // backing comparison table
    const backingBody = document.getElementById('backing-tbody');
    if (backingBody) {
      backingBody.innerHTML = backingRows
        .map((r, i) => {
          const b = [1, 2, 3][i];
          const isSelected = b === state.buffer;
          return `<tr class="${isSelected ? 'highlight' : ''}">
            <td>${b}x${isSelected ? ' ← เลือกอยู่' : ''}</td>
            <td class="positive">${money(r.totalWealth)}</td>
            <td class="positive">${money(r.withdrawnCash)}</td>
            <td>${pct(r.maxActiveFundsDdPct)}</td>
            <td class="${coverageTableClass(r.minActiveCapCoverage)}">${coverageLabel(r.minActiveCapCoverage)}</td>
          </tr>`;
        })
        .join('');
    }

    // fan chart
    const fanOuter = document.getElementById('fan-outer');
    const fanInner = document.getElementById('fan-inner');
    const fanMid = document.getElementById('fan-mid');
    if (fanOuter) fanOuter.setAttribute('points', fan.outerPoints);
    if (fanInner) fanInner.setAttribute('points', fan.innerPoints);
    if (fanMid) fanMid.setAttribute('points', fan.midPoints);

    const p10El = document.getElementById('future-p10');
    const p50El = document.getElementById('future-p50');
    const p90El = document.getElementById('future-p90');
    if (p10El) p10El.textContent = money(lastSample.p10);
    if (p50El) p50El.textContent = money(lastSample.p50);
    if (p90El) p90El.textContent = money(lastSample.p90);

    const bustedCountEl = document.getElementById('busted-count');
    const bustedNoteEl = document.getElementById('busted-note');
    const bustedHorizonEl = document.getElementById('busted-horizon-label');
    if (bustedCountEl) bustedCountEl.textContent = String(lastSample.bustedCount ?? 0);
    if (bustedHorizonEl) bustedHorizonEl.textContent = HORIZON_LABELS[state.horizon] || `${state.horizon} เดือน`;
    if (bustedNoteEl) {
      bustedNoteEl.textContent = (lastSample.bustedCount ?? 0) === 0
        ? 'ไม่มีเส้นทางที่แตกในรอบจำลองนี้ — ไม่ได้แปลว่าเป็นไปไม่ได้'
        : 'เจอแล้วในรอบจำลองนี้ — เป็นไปได้จริง ไม่ใช่แค่ทฤษฎี';
    }
  }

  function recomputeAndRender() {
    render(computeView());
  }

  // --- wiring ---
  let debounceHandle = null;
  function debouncedRecompute() {
    clearTimeout(debounceHandle);
    debounceHandle = setTimeout(recomputeAndRender, 150);
  }

  const capitalInput = document.getElementById('capital-input');
  if (capitalInput) {
    capitalInput.addEventListener('input', () => {
      const v = Number(capitalInput.value);
      state.capital = Number.isFinite(v) && v >= 0 ? v : 0;
      debouncedRecompute();
    });
  }

  const startInput = document.getElementById('start-input');
  if (startInput) {
    startInput.addEventListener('change', () => {
      state.startMonth = startInput.value || START_MIN;
      recomputeAndRender();
    });
  }

  document.querySelectorAll('.chip-row').forEach((row) => {
    const group = row.dataset.group;
    row.querySelectorAll('button').forEach((btn) => {
      btn.addEventListener('click', () => {
        row.querySelectorAll('button').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        const value = Number(btn.dataset.value);
        if (group === 'buffer') state.buffer = value;
        else if (group === 'step') state.step = value;
        else if (group === 'withdraw') {
          state.withdrawPct = value;
          const slider = document.getElementById('withdraw-slider');
          if (slider) slider.value = String(value);
          const valEl = document.getElementById('withdraw-slider-value');
          const remainEl = document.getElementById('withdraw-slider-remain');
          if (valEl) valEl.textContent = String(value);
          if (remainEl) remainEl.textContent = String(100 - value);
        } else if (group === 'horizon') {
          state.horizon = value;
        }
        recomputeAndRender();
      });
    });
  });

  const slider = document.getElementById('withdraw-slider');
  if (slider) {
    slider.addEventListener('input', () => {
      const value = Number(slider.value);
      state.withdrawPct = value;
      const valEl = document.getElementById('withdraw-slider-value');
      const remainEl = document.getElementById('withdraw-slider-remain');
      if (valEl) valEl.textContent = String(value);
      if (remainEl) remainEl.textContent = String(100 - value);
      // sync chip highlight if slider lands exactly on a chip value, else clear all
      const withdrawRow = document.querySelector('.chip-row[data-group="withdraw"]');
      if (withdrawRow) {
        withdrawRow.querySelectorAll('button').forEach((b) => {
          b.classList.toggle('active', Number(b.dataset.value) === value);
        });
      }
      debouncedRecompute();
    });
  }

  // initial paint already matches server-rendered defaults — recompute once
  // anyway so client state (and every subsequent interaction) is driven by
  // the exact same live engine call from the very start.
  recomputeAndRender();
</script>
</Layout>
