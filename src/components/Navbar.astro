---
// Room stays static. The main site owns login/logout and exposes only a safe
// session view to this exact origin.
const MAIN = 'https://www.intensivetrader.com';
const navLinks = [
  { href: MAIN, label: 'หน้าแรก' },
  { href: '/', label: 'Room', active: true },
  { href: `${MAIN}/journal`, label: 'Trading Journal' },
];
---

<nav class="sticky top-0 z-50 glass-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -> เว็บหลัก -->
      <a href={MAIN} class="flex items-center gap-2">
        <img src={`${MAIN}/profile.jpg`} alt="IntensiveTrader" class="w-10 h-10 rounded-full object-cover bg-dark-border" />
        <span class="font-bold text-lg text-gray-light">IntensiveTrader</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={link.active
              ? 'text-primary font-semibold'
              : 'text-gray hover:text-primary transition-colors font-medium'}
          >
            {link.label}
          </a>
        ))}
        <div id="room-auth-desktop" class="min-w-24 text-right text-sm text-gray" aria-live="polite" aria-busy="true">
          กำลังตรวจบัญชี...
        </div>
      </div>

      <!-- Mobile menu button -->
      <button
        type="button"
        class="md:hidden text-gray hover:text-gray-light"
        id="mobile-menu-btn"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="hidden md:hidden" id="mobile-menu">
    <div class="px-4 py-3 space-y-2 bg-dark-card border-t border-dark-border">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={link.active
            ? 'block px-3 py-2 text-primary font-semibold rounded-lg'
            : 'block px-3 py-2 text-gray hover:text-primary hover:bg-dark rounded-lg'}
        >
          {link.label}
        </a>
      ))}
      <div id="room-auth-mobile" class="px-3 py-2 text-center text-sm text-gray" aria-live="polite" aria-busy="true">
        กำลังตรวจบัญชี...
      </div>
    </div>
  </div>
</nav>

<script>
  import { createLatestRequestRunner, installRefreshLifecycle } from '../lib/sessionRefresh';

  const MAIN = 'https://www.intensivetrader.com';
  const SESSION_URL = `${MAIN}/api/auth/session`;
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const desktopAuth = document.getElementById('room-auth-desktop');
  const mobileAuth = document.getElementById('room-auth-mobile');

  interface SafeSession {
    authenticated: boolean;
    email: string | null;
    displayName: string | null;
    role: string | null;
    avatarUrl: string | null;
    banned: boolean;
  }

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  function ownerUrl(path: string): string {
    const url = new URL(path, MAIN);
    url.searchParams.set('redirect', window.location.href);
    return url.toString();
  }

  function createLoginLink(mobile: boolean): HTMLAnchorElement {
    const link = document.createElement('a');
    link.href = ownerUrl('/member');
    link.textContent = 'เข้าสู่ระบบ';
    link.className = mobile
      ? 'block bg-primary px-3 py-2 text-center font-medium text-white rounded-lg'
      : 'inline-flex bg-primary hover:bg-primary-dark text-white px-4 py-2 rounded-lg font-medium transition-colors';
    return link;
  }

  function createLogoutLink(): HTMLAnchorElement {
    const link = document.createElement('a');
    link.href = ownerUrl('/member/logout');
    link.textContent = 'ออกจากระบบ';
    link.className = 'text-xs text-gray hover:text-primary transition-colors';
    link.addEventListener('click', renderGuest);
    return link;
  }

  function avatarUrl(session: SafeSession): string {
    if (session.avatarUrl) return session.avatarUrl;
    const name = session.displayName || session.email || 'U';
    return `https://ui-avatars.com/api/?name=${encodeURIComponent(name)}&background=DC2626&color=fff&size=32`;
  }

  function createAccount(session: SafeSession, mobile: boolean): HTMLElement {
    const wrapper = document.createElement('div');
    wrapper.className = mobile
      ? 'flex items-center justify-between gap-3'
      : 'flex items-center gap-3';

    const dashboard = document.createElement('a');
    dashboard.href = `${MAIN}/member/dashboard`;
    dashboard.className = 'flex min-w-0 items-center gap-2 text-gray-light hover:text-primary transition-colors';

    const avatar = document.createElement('img');
    avatar.src = avatarUrl(session);
    avatar.alt = session.displayName || session.email || 'บัญชีผู้ใช้';
    avatar.className = 'h-8 w-8 shrink-0 rounded-full border border-dark-border object-cover';

    const name = document.createElement('span');
    name.className = 'max-w-32 truncate font-medium';
    name.textContent = session.displayName || session.email || 'สมาชิก';
    dashboard.append(avatar, name);
    wrapper.append(dashboard, createLogoutLink());
    return wrapper;
  }

  function renderGuest() {
    desktopAuth?.replaceChildren(createLoginLink(false));
    mobileAuth?.replaceChildren(createLoginLink(true));
  }

  function renderBanned() {
    const build = () => {
      const wrapper = document.createElement('div');
      wrapper.className = 'flex items-center justify-center gap-2 text-primary';
      const label = document.createElement('span');
      label.textContent = 'บัญชีถูกระงับ';
      wrapper.append(label, createLogoutLink());
      return wrapper;
    };
    desktopAuth?.replaceChildren(build());
    mobileAuth?.replaceChildren(build());
  }

  async function fetchSession(signal: AbortSignal): Promise<SafeSession> {
    const response = await fetch(SESSION_URL, {
      credentials: 'include',
      headers: { Accept: 'application/json' },
      signal
    });
    if (!response.ok) throw new Error('session unavailable');
    const session = (await response.json()) as SafeSession;
    if (typeof session.authenticated !== 'boolean' || typeof session.banned !== 'boolean') {
      throw new Error('invalid session response');
    }
    return session;
  }

  function applySession(session: SafeSession) {
    if (session.banned) {
      renderBanned();
    } else if (session.authenticated) {
      desktopAuth?.replaceChildren(createAccount(session, false));
      mobileAuth?.replaceChildren(createAccount(session, true));
    } else {
      renderGuest();
    }
    desktopAuth?.setAttribute('aria-busy', 'false');
    mobileAuth?.setAttribute('aria-busy', 'false');
  }

  function startSessionRefresh(): () => void {
    const runner = createLatestRequestRunner<SafeSession>({
      load: fetchSession,
      apply: applySession,
      onError: () => applySession({
        authenticated: false,
        email: null,
        displayName: null,
        role: null,
        avatarUrl: null,
        banned: false
      })
    });

    const refresh = () => {
      desktopAuth?.setAttribute('aria-busy', 'true');
      mobileAuth?.setAttribute('aria-busy', 'true');
      void runner.run();
    };
    const stopLifecycle = installRefreshLifecycle({
      refresh,
      windowTarget: window,
      documentTarget: document,
      isDocumentVisible: () => document.visibilityState === 'visible'
    });

    refresh();
    return () => {
      stopLifecycle();
      runner.dispose();
    };
  }

  let stopSessionRefresh = startSessionRefresh();
  window.addEventListener('pagehide', () => {
    stopSessionRefresh();
  });
  window.addEventListener('pageshow', (event) => {
    if (event.persisted) stopSessionRefresh = startSessionRefresh();
  });

</script>
