---
// Navbar โคลนเว็บหลัก intensivetrader.com — room เป็น static (ไม่มี supabase auth)
// cross-subdomain = absolute URL ให้เนียนเป็นเว็บเดียว
const MAIN = 'https://intensivetrader.com';
const navLinks = [
  { href: MAIN, label: 'หน้าแรก' },
  { href: '/', label: 'Room', active: true },
  { href: `${MAIN}/journal`, label: 'Trading Journal' },
];
---

<nav class="sticky top-0 z-50 glass-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -> เว็บหลัก -->
      <a href={MAIN} class="flex items-center gap-2">
        <img src={`${MAIN}/profile.jpg`} alt="IntensiveTrader" class="w-10 h-10 rounded-full object-cover bg-dark-border" />
        <span class="font-bold text-lg text-gray-light">IntensiveTrader</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={link.active
              ? 'text-primary font-semibold'
              : 'text-gray hover:text-primary transition-colors font-medium'}
          >
            {link.label}
          </a>
        ))}
        <a
          href={`${MAIN}/member`}
          class="bg-primary hover:bg-primary-dark text-white px-4 py-2 rounded-lg font-medium transition-colors"
        >
          เข้าสู่ระบบ
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        type="button"
        class="md:hidden text-gray hover:text-gray-light"
        id="mobile-menu-btn"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="hidden md:hidden" id="mobile-menu">
    <div class="px-4 py-3 space-y-2 bg-dark-card border-t border-dark-border">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={link.active
            ? 'block px-3 py-2 text-primary font-semibold rounded-lg'
            : 'block px-3 py-2 text-gray hover:text-primary hover:bg-dark rounded-lg'}
        >
          {link.label}
        </a>
      ))}
      <a
        href={`${MAIN}/member`}
        class="block px-3 py-2 bg-primary text-white text-center rounded-lg font-medium"
      >
        เข้าสู่ระบบ
      </a>
    </div>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
